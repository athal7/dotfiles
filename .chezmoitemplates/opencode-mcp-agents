{{- /* Render MCP wrapping-subagent entries as a JSON fragment (comma-joined
       "name": {…} pairs, no enclosing braces) for splicing into the "agent"
       map after the hand-written agents. ctx: agents (list of specs). */ -}}
{{- $items := list -}}
{{- range $a := .agents -}}
  {{- $obj := dict
        "description" $a.description
        "mode" "subagent"
        "model" (default "anthropic/claude-sonnet-4-6" (index $a "model"))
        "prompt" (printf "{file:./prompts/%s.md}" $a.name) -}}
  {{- $tools := dict -}}
  {{- range $ns := $a.namespaces -}}{{- $_ := set $tools (printf "%s_*" $ns) true -}}{{- end -}}
  {{- $_ := set $obj "tools" $tools -}}
  {{- $perm := dict -}}
  {{- range $ns := $a.namespaces -}}
    {{- range $v := (default (list) (index $a "write_verbs")) -}}
      {{- $_ := set $perm (printf "%s_%s*" $ns $v) "ask" -}}
    {{- end -}}
  {{- end -}}
  {{- range $p := (default (list) (index $a "write_patterns")) -}}
    {{- $_ := set $perm $p "ask" -}}
  {{- end -}}
  {{- $_ := set $perm "bash" "deny" -}}
  {{- $_ := set $perm "skill" "deny" -}}
  {{- $_ := set $obj "permission" $perm -}}
  {{- $items = append $items (printf "%s: %s" ($a.name | quote) ($obj | toPrettyJson)) -}}
{{- end -}}
{{- join ",\n" $items -}}
