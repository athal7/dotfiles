#!/bin/sh
# Restart opencode-web when server-level config or agent files change, then nudge interrupted sessions
# Hashes for change detection:
# opencode.json: {{ joinPath .chezmoi.sourceDir "dot_config/opencode/opencode.json" | include | sha256sum }}
{{- range (glob (joinPath .chezmoi.sourceDir "dot_config/opencode/plugins/*")) }}
# plugin: {{ . | include | sha256sum }}
{{- end }}
# AGENTS.md: {{ joinPath .chezmoi.sourceDir "dot_config/opencode/AGENTS.md.tmpl" | include | sha256sum }}
{{- range (glob (joinPath .chezmoi.sourceDir "dot_config/opencode/agents/*")) }}
# agent: {{ . | include | sha256sum }}
{{- end }}
# dot_agents/capabilities.yaml: {{ joinPath .chezmoi.sourceDir "dot_agents/capabilities.yaml" | include | sha256sum }}
{{- range (glob (joinPath .chezmoi.sourceDir "dot_agents/skills/*/SKILL.md")) }}
# skill: {{ . | include | sha256sum }}
{{- end }}

# Validate config before restarting — a bad config should not take down the running server
config="$HOME/.config/opencode/opencode.json"
if command -v check-jsonschema >/dev/null 2>&1 && [ -f "$config" ]; then
  if ! check-jsonschema --schemafile "https://opencode.ai/config.json" "$config" 2>&1; then
    echo "ERROR: opencode.json failed schema validation — skipping restart to keep current server running" >&2
    echo "Fix the config and run 'chezmoi apply' again" >&2
    exit 1
  fi
fi

label="com.{{ .chezmoi.username }}.opencode-web"
uid=$(id -u)

if launchctl print "gui/$uid/$label" >/dev/null 2>&1; then
  # Snapshot which sessions were running before the restart so we can nudge them after
  db="$HOME/.local/share/opencode/opencode.db"
  interrupted_sessions=""
  if command -v sqlite3 >/dev/null 2>&1 && [ -f "$db" ]; then
    # Sessions with running or pending tool parts updated in the last 10 minutes
    interrupted_sessions=$(sqlite3 -json "$db" "
      SELECT DISTINCT s.id, s.title, s.directory
      FROM part p
      JOIN message m ON p.message_id = m.id
      JOIN session s ON m.session_id = s.id
      WHERE json_extract(p.data, '$.state.status') IN ('running', 'pending')
        AND s.time_archived IS NULL
        AND s.time_updated > (strftime('%s','now') - 600) * 1000
    " 2>/dev/null)
  fi

  launchctl kickstart -k "gui/$uid/$label" 2>/dev/null && echo "Restarted $label" || true

  # Wait for the new server to be ready (up to 30s)
  echo "Waiting for opencode server to be ready..."
  for i in $(seq 1 30); do
    if curl -sf --connect-timeout 1 "http://localhost:4096/session/status" >/dev/null 2>&1; then
      echo "Server ready after ${i}s"
      break
    fi
    sleep 1
  done

  # Nudge any sessions that were interrupted
  if [ -n "$interrupted_sessions" ] && command -v jq >/dev/null 2>&1; then
    echo "$interrupted_sessions" | jq -c '.[]' 2>/dev/null | while read -r session; do
      session_id=$(echo "$session" | jq -r '.id')
      title=$(echo "$session" | jq -r '.title')
      directory=$(echo "$session" | jq -r '.directory')

      # Build context about PTY sessions that may need restarting
      pty_context=""
      if command -v sqlite3 >/dev/null 2>&1 && [ -f "$db" ]; then
        recent_ptys=$(sqlite3 -json "$db" "
          SELECT json_extract(p.data, '$.state.input') as input
          FROM part p
          JOIN message m ON p.message_id = m.id
          WHERE m.session_id = '$session_id'
            AND json_extract(p.data, '$.tool') = 'pty_spawn'
            AND json_extract(p.data, '$.state.status') = 'completed'
            AND p.time_created > (strftime('%s','now') - 600) * 1000
            AND json_extract(p.data, '$.state.input') NOT LIKE '%chezmoi%'
          ORDER BY p.time_created DESC
          LIMIT 3
        " 2>/dev/null)

        if [ -n "$recent_ptys" ] && [ "$recent_ptys" != "[]" ]; then
          pty_context=" PTY sessions that were running and are now dead (may need restarting): $recent_ptys."
        fi
      fi

      prompt="The opencode server was restarted by chezmoi apply (config or skill files changed). Your previous work was interrupted mid-session.$pty_context Please resume where you left off — check your todo list, review recent tool outputs in context, and continue the task."

      curl -s --max-time 5 -X POST "http://localhost:4096/session/$session_id/message?directory=$directory" \
        -H "Content-Type: application/json" \
        -d "{\"parts\": [{\"type\": \"text\", \"text\": $(echo "$prompt" | jq -Rs '.')}]}" \
        >/dev/null 2>&1 && echo "Nudged session: $title ($session_id)" || echo "Failed to nudge: $title"
    done
  fi
else
  echo "$label not loaded, skipping restart"
fi
