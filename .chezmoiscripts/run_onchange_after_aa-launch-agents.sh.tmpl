#!/bin/sh
# LaunchAgent generator — delegates to launchd-yaml.
# Re-runs whenever launchd.yaml changes.
#
# launchd.yaml hash: {{ include ".chezmoidata/launchd.yaml" | sha256sum }}

set -eu

launchd-yaml apply \
  --file "{{ .chezmoi.sourceDir }}/.chezmoidata/launchd.yaml" \
  --self-agent opencode-web
