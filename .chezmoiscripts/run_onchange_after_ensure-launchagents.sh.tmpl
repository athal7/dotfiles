#!/bin/sh
# Bootstrap any managed LaunchAgents that aren't loaded yet.
# Runs when plist files change. Does not force-restart running agents —
# launchd will pick up plist changes on its own, and check-error-logs watches for failures.
# Hashes for change detection:
{{- range (glob (joinPath .chezmoi.sourceDir "Library/LaunchAgents/*.plist.tmpl")) }}
# {{ base . | trimSuffix ".tmpl" }}: {{ . | include | sha256sum }}
{{- end }}

uid=$(id -u)

{{- range (glob (joinPath .chezmoi.sourceDir "Library/LaunchAgents/*.plist.tmpl")) }}
{{ $name := base . | trimSuffix ".tmpl" -}}
plist="{{ $.chezmoi.homeDir }}/Library/LaunchAgents/{{ $name }}"
if [ -f "$plist" ]; then
  label=$(defaults read "$plist" Label 2>/dev/null)
  if [ -n "$label" ] && ! launchctl print "gui/$uid/$label" >/dev/null 2>&1; then
    launchctl bootstrap "gui/$uid" "$plist" 2>/dev/null && echo "Loaded $label" || echo "WARNING: failed to load $label"
  fi
fi
{{- end }}
