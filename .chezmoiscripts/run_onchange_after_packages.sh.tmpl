#!/bin/bash
{{ template "brewenv" . }}

# Homebrew 6.x requires explicit trust before it will load formulae/casks/
# commands from third-party taps (HOMEBREW_REQUIRE_TAP_TRUST is default-on).
# Trust every declared tap so `brew bundle` can install their artifacts —
# their third-party cask/formula artifacts, which silently failed to install before this.
{{ range .packages.taps -}}
brew trust --tap {{ . | quote }}
{{ end }}
brew bundle --file=/dev/stdin <<'EOF'
{{ range .packages.taps -}}
tap {{ . | quote }}
{{ end -}}

cask_args appdir: "/Applications"

{{ range .packages.brews -}}
brew {{ .name | quote }}
{{ end -}}

{{ range .packages.casks -}}
cask {{ .name | quote }}
{{ end -}}
EOF

# Install every tool declared in the mise: list (rendered into
# ~/.config/mise/config.toml by dot_config/mise/config.toml.tmpl). Listing
# versions here as comments makes this script's rendered content change
# whenever the mise: list changes, which is what makes chezmoi re-run it.
{{ range .packages.mise -}}
# - {{ .name }}@{{ .version }}
{{ end -}}
mise install
mise reshim
