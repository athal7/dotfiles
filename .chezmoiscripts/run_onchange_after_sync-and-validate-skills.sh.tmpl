#!/bin/sh
# Sync and validate agent skills when skill files change.
# Hashes for change detection (every file inside per-skill folders + external-skill
# manifest + deployed-state presence so a missing external skill triggers re-run):
{{- range (glob (joinPath .chezmoi.sourceDir "skills/*/**/*")) }}
{{- if not (stat .).isDir }}
# skill-file: {{ . | include | sha256sum }}
{{- end }}
{{- end }}
# gh_skills: {{ .packages.skills | toJson | sha256sum }}
{{- range .packages.skills }}
{{- if hasKey . "repo" }}
# external-present: {{ .skill }}={{ if (joinPath (env "HOME") ".agents/skills" .skill "SKILL.md" | stat) }}1{{ else }}0{{ end }}
{{- end }}
{{- if hasKey . "source" }}
{{- range (glob (joinPath $.chezmoi.sourceDir .source .match "**/*")) }}
{{- if not (stat .).isDir }}
# local-skill-file: {{ . | include | sha256sum }}
{{- end }}
{{- end }}
{{- end }}
{{- end }}

SKILLS_SRC="{{ .chezmoi.sourceDir }}/skills"
SKILLS_DEST="$HOME/.agents/skills"

# Sync skills from repo to destination, replacing it wholesale to remove orphans.
# AGENTS.md and README.md at the skills/ root are authoring/repo-meta docs —
# only useful in the source tree, never in the deployed agent skill list.
echo "syncing skills from $SKILLS_SRC..."
rm -rf "$SKILLS_DEST"
mkdir -p "$SKILLS_DEST"
cp -r "$SKILLS_SRC"/. "$SKILLS_DEST/"
rm -f "$SKILLS_DEST/AGENTS.md" "$SKILLS_DEST/README.md"

# Mirror locally-generated skills (declared in packages.yaml `skills` with a
# `source`) into the global skill dir so they're available outside their
# originating project. These come from external CLIs that only generate skills
# project-locally; copying their output keeps them version-matched to the CLI.
# Skips gracefully when a source dir is absent (e.g. fresh machine).
{{- range .packages.skills }}
{{- if hasKey . "source" }}
LOCAL_SKILLS_SRC="{{ $.chezmoi.sourceDir }}/{{ .source }}"
if [ -d "$LOCAL_SKILLS_SRC" ]; then
  for skill_dir in "$LOCAL_SKILLS_SRC"/{{ .match }}/; do
    [ -d "$skill_dir" ] || continue
    cp -r "${skill_dir%/}" "$SKILLS_DEST/"
    echo "mirrored local skill: $(basename "$skill_dir")"
  done
fi
{{- end }}
{{- end }}

# Install external skills via gh skill install
# stdin redirected from /dev/null so gh detects non-interactive mode;
# --agent opencode prevents the "select target agent" prompt.
{{ range .packages.skills -}}
{{- if hasKey . "repo" }}
echo "installing {{ .skill }} from {{ .repo }}..."
gh skill install {{ .repo }} {{ .skill }} --dir "$SKILLS_DEST" --agent opencode --force < /dev/null
{{ end -}}
{{- end }}

# Host-local private skill installs — for skills in PRIVATE repos that must not
# be referenced in this public repo. The file is untracked and host-specific
# (same spirit as ~/.config/zsh/private.zsh). It receives SKILLS_DEST and runs
# its own `gh skill install ... --dir "$SKILLS_DEST"` lines. Runs here because
# the rebuild above wipes SKILLS_DEST, so private skills must be reinstalled too.
PRIVATE_SKILLS_INSTALL="$HOME/.config/agentskills/private-install.sh"
if [ -f "$PRIVATE_SKILLS_INSTALL" ]; then
  echo "running host-local private skill installs..."
  SKILLS_DEST="$SKILLS_DEST" sh "$PRIVATE_SKILLS_INSTALL"
fi

# agentskills validate — checks spec compliance for local skills
if ! command -v agentskills >/dev/null 2>&1; then
  echo "agentskills not found — skipping spec validation (install: uv tool install skills-ref)" >&2
else
  failed=0
  warned=0

  for skill_dir in "$SKILLS_SRC"/*/; do
    result=$(agentskills validate "$skill_dir" 2>&1)
    if echo "$result" | grep -q "Validation failed"; then
      # Unexpected fields from open proposals (prerequisite-skills) are warnings, not errors
      if echo "$result" | grep -q "Unexpected fields"; then
        echo "WARN: $(basename $skill_dir): $result" >&2
        warned=$((warned + 1))
      else
        echo "ERROR: $(basename $skill_dir): $result" >&2
        failed=$((failed + 1))
      fi
    fi
  done

  if [ $failed -gt 0 ]; then
    echo "agentskills validation: $failed error(s) — fix before using skills" >&2
    exit 1
  fi

  if [ $warned -gt 0 ]; then
    echo "agentskills validation: $warned warning(s) from open spec proposals (non-blocking)"
  fi

  echo "agentskills validation: ok"
fi
