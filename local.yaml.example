# Machine-specific config for chezmoi.
# Copy to ~/.local/share/chezmoi/.chezmoidata/local.yaml and fill in your values.
# This file is never committed — it lives only on the machine.

# Per-org config keyed by GitHub org login. Orgs not listed fall back to defaults
# (GitHub Issues for issue tracking; no automated code review).
#
# Per-org keys:
#   issues           : "linear" if the org uses Linear (anything else → default GitHub Issues)
#   automated_review : config for AI/embedded code review (Copilot, Codex, etc.). Omit if not available.
#     bot_login : the GitHub user.login the bot posts as (used to filter PR review comments)
#     auto_runs : true if the bot reviews automatically on PR open; false if it must be triggered
#     trigger   : how to invoke the bot. Supported forms:
#                   "add_reviewer @handle"      — add as PR reviewer (Copilot)
#                   "comment @handle <text>"    — post a top-level comment to mention the bot
orgs:
  your-work-org:
    issues: linear
    automated_review:
      bot_login: copilot-pull-request-reviewer
      auto_runs: true
      trigger: add_reviewer @copilot

# Secrets manifest — each entry maps a name to its provider.
# provider: op   — fetched via 1Password CLI
# provider: keychain — fetched via macOS Keychain (service: chezmoi)
secrets:
  slack_user_token:
    provider: op
    account: your-1password-account
    vault: your-vault
    item: your-item-id
    field: user_token
  slack_token:
    provider: op
    account: your-1password-account
    vault: your-vault
    item: your-item-id
    field: token
  slack_user_id:
    provider: op
    account: your-1password-account
    vault: your-vault
    item: your-item-id
    field: user_id
  figma_access_token:
    provider: op
    account: your-1password-account
    vault: your-vault
    item: your-item-id
    field: access_token
  es_api_key:
    provider: op
    account: your-1password-account
    vault: your-vault
    item: your-item-id
    field: api_key
  es_url:
    provider: op
    account: your-1password-account
    vault: your-vault
    item: your-item-id
    field: url
# Calendar configuration
calendars:
  personal:
    name: "Personal"
    sync_to:
      - work
    ignore_patterns:
      - CSA Delivery
  work:
    name: "Work"
    sync_to:
      - personal
    lunch_guard: true
    inbound_start: 9
    inbound_end: 17
    inbound_days: [mon, tue, wed, thu, fri]
    title_mappings:
      lunch: Lunch
      standup: Standup

# Reminders lists
reminders:
  personal:
    name: "Personal"
