# Machine-specific config for chezmoi.
# Copy to ~/.local/share/chezmoi/.chezmoidata/local.yaml and fill in your values.
# This file is never committed — it lives only on the machine.

# Per-org config keyed by GitHub org login. Orgs not listed fall back to defaults
# (GitHub Issues for issue tracking; no automated code review).
#
# Per-org keys:
#   issues           : "linear" if the org uses Linear (anything else → default GitHub Issues)
#   automated_review : config for AI/embedded code review (Copilot, Codex, etc.). Omit if not available.
#     bot_login : the GitHub user.login the bot posts as (used to filter PR review comments)
orgs:
  your-work-org:
    issues: linear
    automated_review:
      bot_login: copilot-pull-request-reviewer

# Production service → local repo mapping for the daily fix-prod-errors task.
# Keys are Elastic APM service.name values; values are repo directory names under ~/code.
# Used by the /fix-prod-errors command to decide which repo to create a worktree in.
prod_services:
  your-api-service: your-api-repo
  your-worker-service: your-worker-repo

# Knowledge-base collectors to run during /kb-enrich. Each name maps to a recipe
# file at ~/.config/kb/collectors/<name>.md. Only listed collectors run; omit one
# to disable it without deleting its recipe.
kb:
  collectors: [opencode, slack, zoom, linear, gh]

runlayer:
  zoom_mcp_url: ""  # Runlayer MCP proxy URL for the Zoom connector
  self_mcp_url: ""  # Runlayer MCP proxy URL for the self/discovery server
  slack_mcp_url: ""  # Runlayer MCP proxy URL for the Slack connector
  atlassian_mcp_url: ""  # Runlayer MCP proxy URL for the Confluence/Jira connector

# Secrets manifest — each entry declares a name. Values are stored in the macOS
# Keychain under service "chezmoi" with account = the name. Populate them via:
#   security add-generic-password -U -s "chezmoi" -a "<name>" -w "<value>"
# Agents read values via `security find-generic-password -s chezmoi -a <name> -w` —
# this works non-interactively, including from remote sessions, with no biometric prompts.
secrets:
  slack_token: {}
  slack_user_id: {}
  es_api_key: {}
  es_url: {}
  linear_api_key: {}
  pagerduty_api_token: {}
# Calendar configuration
calendars:
  personal:
    name: "Personal"
    sync_to:
      - work
  family:
    name: "Family"
    babysitter_check: true
    # Patterns for sync-calendars (events not copied to other calendars)
    ignore_patterns:
      - CSA Delivery
    # Events whose titles match any of these strings (case-insensitive) are
    # skipped by babysitter-check — use for events where you're with the kids
    # and don't need a sitter (e.g. activities you're attending together).
    babysitter_ignore_patterns:
      - Soccer
      - School Play
  work:
    name: "Work"
    attention_check: true
    sync_to:
      - personal
    lunch_guard: true
    inbound_start: 9
    inbound_end: 17
    inbound_days: [mon, tue, wed, thu, fri]
    title_mappings:
      lunch: Lunch
      standup: Standup

# Reminders lists
reminders:
  personal:
    name: "Personal"
  work:
    name: "Work"
    attention_check: true
