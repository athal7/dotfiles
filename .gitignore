# Allow favicon (overrides global gitignore)
!favicon.svg

# Allow repo-level opencode config
!.opencode/opencode.json

# Allow .sql files (skill query scripts)
!*.sql

# opencode plugin lock file (generated, not committed)
.opencode/package-lock.json

# gws CLI download artifacts
download.html

# talisman scan reports
talisman_report/

# Machine-specific local config — lives only on the machine, never committed
.chezmoidata/local.yaml

# bench-*.md output files (scratch, not config)
bench-*.md

# OpenSpec specs — track living requirements, ignore working changes
# (openspec/ is globally ignored via ~/.config/git/ignore)
!openspec/
openspec/changes/

# Python bytecode
__pycache__/
*.pyc
