[".agents/skills/ical-cli"]
    type = "archive"
    url = "https://github.com/BRO3886/ical/archive/refs/heads/main.tar.gz"
    stripComponents = 3
    include = ["*/skills/ical-cli/**"]
    refreshPeriod = "168h"

[".agents/skills/linear-cli"]
    type = "archive"
    url = "https://github.com/schpet/linear-cli/archive/refs/heads/main.tar.gz"
    stripComponents = 3
    include = ["*/skills/linear-cli/SKILL.md", "*/skills/linear-cli/references/**"]
    refreshPeriod = "168h"

{{ range .packages.github_releases -}}
{{ if eq .target "Applications" -}}
[{{ printf "Applications/%s" .app | quote }}]
    type = {{ .type | quote }}
    url = {{ gitHubLatestReleaseAssetURL .repo .asset | quote }}
    stripComponents = 1
    refreshPeriod = {{ .refresh_period | quote }}

{{ else -}}
[{{ .target | quote }}]
    type = {{ .type | quote }}
    url = {{ gitHubLatestReleaseAssetURL .repo .asset | quote }}
    {{- if eq .type "archive-file" }}
    path = {{ .path | quote }}
    {{- end }}
    {{- if index . "executable" }}
    executable = true
    {{- end }}
    refreshPeriod = {{ .refresh_period | quote }}

{{ end -}}
{{ end -}}
