{{ range .packages.github_releases -}}
{{ if eq .target "Applications" -}}
[{{ printf "Applications/%s" .app | quote }}]
    type = {{ .type | quote }}
    url = {{ gitHubLatestReleaseAssetURL .repo .asset | quote }}
    stripComponents = 1
    refreshPeriod = {{ .refresh_period | quote }}

{{ else -}}
[{{ .target | quote }}]
    type = {{ .type | quote }}
    url = {{ gitHubLatestReleaseAssetURL .repo .asset | quote }}
    {{- if eq .type "archive-file" }}
    path = {{ .path | quote }}
    {{- end }}
    {{- if index . "executable" }}
    executable = true
    {{- end }}
    refreshPeriod = {{ .refresh_period | quote }}

{{ end -}}
{{ end -}}
