sourceDir = {{ .chezmoi.sourceDir | quote }}

[edit]
    command = "nvim"
[diff]
    exclude = ["scripts"]

[data]
    fullName = {{ promptStringOnce . "fullName" "Full name" | quote }}
    email = {{ promptStringOnce . "email" "Work email" | quote }}
    codeDir = {{ promptStringOnce . "codeDir" "Code directory" (joinPath .chezmoi.homeDir "code") | quote }}

[data.calendars]
    personal = {{ promptStringOnce . "calendars.personal" "Personal calendar name" | quote }}
    work = {{ promptStringOnce . "calendars.work" "Work calendar name" | quote }}
    family = {{ promptStringOnce . "calendars.family" "Family calendar name" | quote }}

[data.feeds]
    libertyville_rec = {{ promptStringOnce . "feeds.libertyville_rec" "Libertyville Recreation ICS URL" | quote }}
