sourceDir = {{ .chezmoi.sourceDir | quote }}

[edit]
    command = "nvim"
[diff]
    exclude = ["scripts"]

[data]
    fullName = {{ promptStringOnce . "fullName" "Full name" | quote }}
    email = {{ promptStringOnce . "email" "Work email" | quote }}

# [data.env] — all entries are rendered into ~/.env as SCREAMING_SNAKE_CASE vars.
# Keys must be camelCase with no consecutive capitals (e.g. esUrl not esURL).
# Non-secret config values (like codeDir) are included here when skills reference
# them as environment variables.
[data.env]
    codeDir = {{ promptStringOnce . "env.codeDir" "Code directory" (joinPath .chezmoi.homeDir "code") | quote }}
    githubToken = {{ promptStringOnce . "env.githubToken" "GitHub token" | quote }}

# Optional — uncomment as needed:
#
# [data.env] additions:
#     wakatimeApiKey = "..."     — Wakatime time tracking
#     slackUserToken = "..."     — Slack skill (user token)
#     slackUserId = "..."        — Slack skill (your user ID)
#     figmaAccessToken = "..."   — Figma skill
#     esUrl = "..."              — Elasticsearch skill (cluster URL)
#     esApiKey = "..."           — Elasticsearch skill (API key)

# Calendar configuration. Each key is an arbitrary label used by scripts.
# Attributes:
#   name                    — Apple Calendar display name (required)
#   readonly                — if true, never write mirror events to this calendar (default: false)
#   sync_to                 — list of calendar keys to mirror events into
#   lunch_guard             — if true, lunch-guard protects this calendar
#   family_scheduler_target — if true, family-scheduler writes new events here
#
# [data.calendars.personal]
#     name = "Personal"
#     sync_to = ["work"]
#
# [data.calendars.work]
#     name = "Work"
#     sync_to = ["personal"]
#     lunch_guard = true
#
# [data.calendars.family]
#     name = "Family"
#     readonly = true
#     sync_to = ["work"]
#     family_scheduler_target = true

# Exclude specific events from syncing. Key is event title (case-insensitive),
# value is the source calendar label to match ("*" matches any source).
# Example:
# [data.calendars.syncExclude]
#     "CSA Delivery" = "family"

# [data.feeds] — optional, ICS feeds for family-scheduler; key becomes display name
# [data.feeds]
#     my_rec_center = "https://example.com/feed.ics"
