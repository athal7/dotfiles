#!/usr/bin/env bash
# post-meeting.sh — shim required by minutes [hooks] post_record (path only, no inline commands).
# Dispatches the post-meeting agent skill via the OpenCode API (fire-and-forget).
# Triggered by [hooks] post_record in ~/.config/minutes/config.toml

API="http://localhost:4096"
DIR="$(minutes paths 2>/dev/null | grep '^output_dir:' | awk '{print $2}')"
DIR="${DIR:-$HOME/meetings}"

# Reuse an idle session in the meetings dir, or create a new one
SESSION_ID=$(curl -s "$API/session?directory=$DIR&roots=true" \
  | jq -r '[.[] | select(.time.archived == null)] | sort_by(.time.updated) | reverse | .[0].id // empty')

if [ -n "$SESSION_ID" ]; then
  STATUS=$(curl -s "$API/session/status" | jq -r --arg id "$SESSION_ID" '.[$id].type // "unknown"')
  [ "$STATUS" != "idle" ] && SESSION_ID=""
fi

if [ -z "$SESSION_ID" ]; then
  SESSION_ID=$(curl -s -X POST "$API/session?directory=$DIR" \
    -H "Content-Type: application/json" -d '{}' | jq -r '.id')
fi

# Fire and forget — session keeps running server-side after curl exits
# Send the full task so the agent runs cleanup automatically without user approval.
curl -s --max-time 10 -X POST "$API/session/$SESSION_ID/message?directory=$DIR" \
  -H "Content-Type: application/json" \
  -d '{"parts": [{"type": "text", "text": "Load the post-meeting skill and run post-meeting cleanup on the most recent meeting. Do not ask for confirmation — run all steps automatically and report results when done."}]}' || true
