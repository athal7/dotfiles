output_dir = "{{ .chezmoi.homeDir }}/meetings"

[identity]
name = "{{ .fullName }}"
{{- if .email }}
email = "{{ .email }}"
{{- end }}

[transcription]
model = "medium"
model_path = "{{ .chezmoi.homeDir }}/.minutes/models"
min_words = 3
language = "en"
noise_reduction = true

[diarization]
# "auto" uses pyannote-rs if models are downloaded, otherwise skips gracefully.
# Run `minutes setup --diarization` to download the ~34MB ONNX models.
engine = "auto"
embedding_model = "cam++-lm"  # Higher accuracy (~12% lower EER) than cam++
threshold = 0.25              # Aggressive speaker splitting (lowered from 0.4 due to heavy under-splitting)

[voice]
# Enabled automatically when voice profiles are enrolled via `minutes enroll`.
enabled = true
match_threshold = 0.45  # cam++-lm produces lower cosine similarities than cam++

[summarization]
engine = "ollama"
ollama_url = "http://localhost:11434"
ollama_model = "gemma4:e4b"
# engine = "agent"
# agent_command = "claude"

[knowledge]
enabled = true
path = "{{ .chezmoi.homeDir }}/meetings/knowledge"
adapter = "wiki"        # people/{slug}.md with facts grouped by category
engine = "none"         # Structured YAML only — LLM transcript extraction not yet implemented upstream
min_confidence = "strong"

[recording.sources]
# voice = "default" tracks whatever macOS system default input is set
# (AirPods, Studio Display, MacBook Pro mic — switches automatically)
# call = "auto" detects ZoomAudioDevice/BlackHole/etc automatically
# Separate stems enable much better diarization (each speaker isolated)
voice = "default"
call = "auto"

[call_detection]
# macOS-only. Watches for active calls in the listed apps and prompts to record.
enabled = true
poll_interval_secs = 1
cooldown_minutes = 5
apps = ["zoom.us"]
stop_when_call_ends = true      # Show countdown prompt when call app exits; stop if no action taken

[assistant]
agent = "opencode"
agent_args = ["-m", "ollama/gemma4:e4b"]

[screen_context]
enabled = true
interval_secs = 30
keep_after_summary = false

[watch]
paths = ["{{ .chezmoi.homeDir }}/.minutes/inbox"]
settle_delay_ms = 2000          # Wait for cloud-synced files to finish writing
dictation_threshold_secs = 120  # Files shorter than this → fast memo pipeline (no diarization)

[hooks]
post_record = "{{ .chezmoi.homeDir }}/.config/minutes/post-meeting.sh"

[search]
engine = "builtin"

[security]
allowed_audio_dirs = []

[palette]
shortcut_enabled = true
shortcut = "CmdOrCtrl+Shift+K"
