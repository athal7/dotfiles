output_dir = "{{ .chezmoi.homeDir }}/meetings"

[transcription]
engine = "whisper"
model = "large-v3"
model_path = "{{ .chezmoi.homeDir }}/.minutes/models"
min_words = 3
language = "en"
vad_model = "silero-v6.2.0"
noise_reduction = true
parakeet_binary = "parakeet"
parakeet_model = "tdt-600m"
parakeet_boost_limit = 0
parakeet_boost_score = 2.0
parakeet_fp16 = true
parakeet_sidecar_enabled = false
parakeet_fp16_blacklist_reset = false
parakeet_vocab = "tdt-600m.tokenizer.vocab"

[diarization]
engine = "auto"
model_path = "{{ .chezmoi.homeDir }}/.minutes/models/diarization"
threshold = 0.25
embedding_model = "cam++-lm"
stem_correlation_threshold = 1.0

[summarization]
engine = "agent"
agent_command = "opencode"
chunk_max_tokens = 4000
ollama_url = "http://localhost:11434"
ollama_model = "gemma4:e4b"
openai_compatible_base_url = "http://localhost:11434/v1"
openai_compatible_model = "llama3.2"
openai_compatible_api_key_env = ""
mistral_model = "mistral-large-latest"
language = "auto"

[search]
engine = "builtin"

[daily_notes]
enabled = false
path = "{{ .chezmoi.homeDir }}/meetings/daily"

[security]
allowed_audio_dirs = []

[watch]
paths = ["{{ .chezmoi.homeDir }}/.minutes/inbox"]
extensions = [
    "m4a",
    "wav",
    "mp3",
    "ogg",
    "webm",
]
type = "memo"
diarize = false
delete_source = false
settle_delay_ms = 2000
dictation_threshold_secs = 120

[assistant]
agent = "opencode"
agent_args = [
    "-m",
    "ollama/gemma4:e4b",
]

[privacy]
hide_from_screen_share = true

[screen_context]
enabled = true
interval_secs = 30
keep_after_summary = false

[desktop_context]
enabled = false
capture_window_titles = true
capture_browser_context = false
allowed_apps = []
denied_apps = []
allowed_domains = []
denied_domains = []

[calendar]
enabled = true

[call_detection]
enabled = true
poll_interval_secs = 1
cooldown_minutes = 5
apps = ["zoom.us"]
stop_when_call_ends = true
call_end_stop_countdown_secs = 30

[identity]
name = "{{ .fullName }}"
{{- if .email }}
email = "{{ .email }}"
{{- end }}
emails = []
aliases = []

[vault]
enabled = false
path = ""
meetings_subdir = "areas/meetings"
strategy = "auto"

[dictation]
backend = "whisper"
destination = "clipboard"
accumulate = true
daily_note_log = true
cleanup_engine = ""
auto_paste = false
auto_paste_restore = true
silence_timeout_ms = 2000
max_utterance_secs = 120
destination_file = ""
destination_command = ""
model = "base"
shortcut_enabled = false
shortcut = "CmdOrCtrl+Shift+Space"
hotkey_enabled = false
hotkey_keycode = 57

[voice]
enabled = true
match_threshold = 0.44999998807907104

[live_transcript]
backend = "whisper"
model = ""
max_utterance_secs = 30
save_wav = true
shortcut_enabled = false
shortcut = "CmdOrCtrl+Shift+L"

[recording]
silence_reminder_secs = 300
silence_threshold = 3
silence_auto_stop_secs = 1800
max_duration_secs = 28800
min_disk_space_mb = 500
auto_call_intent = false
allow_degraded_call_capture = false
capture_backend = "core-audio-tap"

[recording.sources]
voice = "default"
call = "auto"

[hooks]
post_record = "{{ .chezmoi.homeDir }}/.config/minutes/post-meeting.sh"

[knowledge]
enabled = true
path = "{{ .chezmoi.homeDir }}/meetings/knowledge"
adapter = "wiki"
engine = "none"
agent_command = "claude"
log_file = "log.md"
index_file = "index.md"
min_confidence = "strong"

[palette]
shortcut_enabled = true
shortcut = "CmdOrCtrl+Shift+K"
