output_dir = "{{ .chezmoi.homeDir }}/meetings"

[identity]
name = "{{ .fullName }}"

[transcription]
model = "small"
model_path = "{{ .chezmoi.homeDir }}/.minutes/models"
min_words = 3

[diarization]
engine = "none"

[summarization]
engine = "agent"

[hooks]
post_record = "{{ .chezmoi.homeDir }}/.config/minutes/post-meeting.sh"

[search]
engine = "builtin"

[security]
allowed_audio_dirs = []
