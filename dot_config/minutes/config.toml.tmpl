output_dir = "{{ .chezmoi.homeDir }}/meetings"

[identity]
name = "{{ .fullName }}"

[transcription]
model = "small"
model_path = "{{ .chezmoi.homeDir }}/.minutes/models"
min_words = 3

[diarization]
engine = "none"

[summarization]
engine = "agent"
agent_command = "claude"  # uses Claude Code subscription, no API key needed

[search]
engine = "builtin"

[security]
allowed_audio_dirs = []
