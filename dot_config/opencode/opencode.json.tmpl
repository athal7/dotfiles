{{- /*
opencode.json — OpenCode agent configuration.

Generates ~/.config/opencode/opencode.json via chezmoi. Covers:
  - Model selection (cloud and local via LM Studio)
  - Bash permissions: default-allow with curated ask/deny guardrails. Guardrails (system-destructive commands) and named allow-lists live in `.chezmoidata/bash-permissions.yaml`, rendered per-agent via the `opencode-bash` template partial; package-specific gates still live per-tool in packages.yaml. The `lead` agent defaults to `deny` (forcing delegation) with a read-only diagnostics allow-list; other subagents inherit the permissive global block
  - MCP server connections
  - Plugin wiring (skill injection, custom commands)
  - Agent-specific permission and skill overrides (lead, plan, qa, build, explore, scout, general)

Local model setup: LM Studio serves the non-thinking MLX Mixture-of-Experts
model Qwen3-30B-A3B-Instruct-2507 (4-bit MLX) for agentic coding and the kb
meeting pipeline. It is also wired as opencode's `small_model`, so it powers
session-title generation, the `/rename` command (commands/rename.md +
plugins/session-rename.ts), and project-copy naming. It never emits <think>
blocks, so no thinking-suppression is
needed. Install the cask via chezmoi, run `npx lmstudio install-cli`, enable
"Run server on login", and download via the full HF URL (the LM Studio catalog
slug does not resolve): `lms get https://huggingface.co/mlx-community/Qwen3-30B-A3B-Instruct-2507-4bit -y`.
Reference in opencode as lmstudio/qwen3-30b-a3b-instruct-2507.
*/ -}}
{{- /* Collect per-package patterns from packages.yaml — flat format (pattern: allow/ask).
       NOTE: $globalBash holds ONLY package perms; guardrails/allow-lists now come
       from .chezmoidata/bash-permissions.yaml via the opencode-bash partial. */ -}}
{{- $globalBash := dict -}}
{{- range $list := .packages -}}
  {{- if kindIs "slice" $list -}}
    {{- range $entry := $list -}}
      {{- if kindIs "map" $entry -}}
        {{- $perms := index $entry "permissions" -}}
        {{- if $perms -}}
          {{- range $pattern, $action := $perms -}}
            {{- $_ := set $globalBash $pattern $action -}}
          {{- end -}}
        {{- end -}}
      {{- end -}}
    {{- end -}}
  {{- end -}}
{{- end -}}
{{- /* Bash permission data: guardrails, named allow-lists, per-agent specs. */ -}}
{{- $bp := .bashPermissions -}}
{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "lead",
  "server": {
    "hostname": "127.0.0.1"
  },
  "plugin": [
    ["./lib/skill-inject.ts", {
      "architecture": ["code-quality"],
      "attention": ["opencode", "ical-cli", "reminders"],
      "communication": ["knowledge-base"],
      "elasticsearch": [{"skill": "xh", "context": "All requests use xh --ignore-stdin --session=agent for auth"}],
      "observability": ["elasticsearch"],
      "pagerduty": [{"skill": "xh", "context": "All requests use xh --ignore-stdin --session=agent for auth"}],
      "push": ["commit", "branching"]
    }],
    "@tarquinen/opencode-dcp@3.1.12"
  ],
  "permission": {
    "skill": "allow",
    "lsp": "allow",
    "websearch": "allow",
    "external_directory": {
      "*": "ask",
      "~/code/**": "allow",
      "~/.local/share/**": "allow",
      "~/.agents/skills/**": "allow",
      "/tmp/**": "allow"
    },
    "bash": {{ includeTemplate "opencode-bash" (dict "spec" $bp.agents.global "lists" $bp.lists "guardrails" $bp.guardrails "packages" $globalBash) | indent 4 | trim }}
  },
  {{- /*
  Per-agent skill deny lists — blocked by sst/opencode#21793
  (permission.skill patterns not enforced). When fixed, add to each agent:

  plan:  deny commit, push, branching, chezmoi
  build: deny commit, push, branching, architecture, thinking-tools
  */ -}}
  {{- /*
  NOTE: always set `model` explicitly on each agent — never rely on top-level
  model inheritance for subagents. Testing confirmed that dispatched subagents
  inherit the CALLING AGENT's model, not the top-level default. So if
  lead=sonnet and plan has no model field, plan runs on sonnet even though
  the top-level default is opus.
  */ -}}
  "agent": {
    "lead": {
      "mode": "primary",
      "model": "anthropic/claude-sonnet-5",
      "prompt": "{file:./prompts/lead.md}",
      "permission": {
        "task": "allow",
        "edit": "deny",
        "write": "deny",
        "bash": {{ includeTemplate "opencode-bash" (dict "spec" $bp.agents.lead "lists" $bp.lists "guardrails" $bp.guardrails "packages" $globalBash) | indent 8 | trim }}
      }
    },
    "plan": {
      "description": "Deep analysis and architectural thinking subagent. Dispatched by lead for design decisions, complex tradeoffs, and architectural review. Read-only.",
      "mode": "subagent",
      "model": "anthropic/claude-opus-4-8",
      "prompt": "{file:./prompts/plan.md}",
      "permission": {
        "edit": "deny",
        "write": "deny"
      },
      "tools": {
        "context7_*": true
      }
    },
    "qa": {
      "description": "Functional QA — drives the running app in a browser (Firefox MCP) to verify UI/behavior. Read-only re: code.",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-5",
      "prompt": "{file:./prompts/qa.md}",
      "permission": {
        "edit": "deny",
        "write": "deny"
      },
      "tools": {
        "firefox-devtools_*": true
      }
    },
    "build": {
      "description": "Focused worker subagent dispatched by lead. Executes implementation work under TDD discipline. Has edit/write access and local dev tooling. Returns a tight summary when done.",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-5",
      "prompt": "{file:./prompts/build.md}",
      "steps": 30,
      "permission": {
        "edit": "allow",
        "write": "allow",
        "bash": {{ includeTemplate "opencode-bash" (dict "spec" $bp.agents.build "lists" $bp.lists "guardrails" $bp.guardrails "packages" $globalBash) | indent 8 | trim }}
      },
      "tools": {
        "figma-desktop_*": true,
        "context7_*": true
      }
    },
    "explore": {
      "model": "anthropic/claude-sonnet-5",
      "prompt": "{file:./prompts/explore.md}",
      "permission": {
        "edit": "deny",
        "write": "deny"
      }
    },
    "scout": {
      "description": "External research — library/framework docs, dependency source, changelogs. Read-only; uses webfetch and context7.",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-5",
      "prompt": "{file:./prompts/scout.md}",
      "permission": {
        "edit": "deny",
        "write": "deny"
      },
      "tools": {
        "context7_*": true
      }
    },
    "general": {
      "description": "Multi-step research and read-only work that doesn't fit explore/scout/plan/qa — the reads catch-all.",
      "model": "anthropic/claude-sonnet-5",
      "permission": {
        "edit": "deny",
        "write": "deny"
      }
    },
    "zoom": {
      "description": "Reaches Zoom via Runlayer MCP (OAuth). Dispatched to fetch meeting summaries, transcripts, recordings. Returns a tight distilled summary, never raw dumps.",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-6",
      "prompt": "{file:./prompts/zoom.md}",
      "tools": {
        "runlayer-zoom_*": true
      },
      "permission": {
        "bash": "deny",
        "skill": "deny"
      }
    },
    "slack": {
      "description": "Reaches Slack via Runlayer MCP (OAuth). Dispatched to search, read, and post messages, threads, canvases, and files. Returns a tight distilled summary, never raw dumps.",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-6",
      "prompt": "{file:./prompts/slack.md}",
      "tools": {
        "runlayer-slack_*": true
      },
      "permission": {
        "runlayer-slack_slack_send_*": "ask",
        "runlayer-slack_slack_schedule_*": "ask",
        "runlayer-slack_slack_add_*": "ask",
        "runlayer-slack_slack_create_*": "ask",
        "bash": "deny",
        "skill": "deny"
      }
    },
    "atlassian": {
      "description": "Reaches Confluence and Jira via Runlayer MCP (OAuth). Dispatched to search and read pages, spaces, and issues; write actions (create/update/transition/comment) require explicit confirmation. Returns a tight distilled summary, never raw dumps.",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-6",
      "prompt": "{file:./prompts/atlassian.md}",
      "tools": {
        "runlayer-atlassian_*": true
      },
      "permission": {
        "runlayer-atlassian_create*": "ask",
        "runlayer-atlassian_update*": "ask",
        "runlayer-atlassian_edit*": "ask",
        "runlayer-atlassian_transition*": "ask",
        "runlayer-atlassian_add*": "ask",
        "bash": "deny",
        "skill": "deny"
      }
    },
    "github": {
      "description": "Reaches GitHub via its official remote MCP server. Dispatched to search and read issues, pull requests, and repos; write actions (create/update/merge/comment) require explicit confirmation. Returns a tight distilled summary, never raw dumps.",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-6",
      "prompt": "{file:./prompts/github.md}",
      "tools": {
        "github_*": true
      },
      "permission": {
        "github_create_*": "ask",
        "github_update_*": "ask",
        "github_delete_*": "ask",
        "github_merge_*": "ask",
        "github_push_*": "ask",
        "github_fork_*": "ask",
        "github_add_*": "ask",
        "github_assign_*": "ask",
        "github_request_*": "ask",
        "github_dismiss_*": "ask",
        "github_mark_*": "ask",
        "github_manage_*": "ask",
        "github_star_repository": "ask",
        "github_unstar_repository": "ask",
        "github_actions_run_trigger": "ask",
        "github_*_write": "ask",
        "bash": "deny",
        "skill": "deny"
      }
    },
    "google": {
      "description": "Reaches Gmail, Calendar, Drive, Docs, and Sheets via Runlayer MCP (OAuth). Dispatched to search and read messages, events, and files; write actions (send/create/update/delete) require explicit confirmation. Returns a tight distilled summary, never raw dumps.",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-6",
      "prompt": "{file:./prompts/google.md}",
      "tools": {
        "runlayer-gmail_*": true,
        "runlayer-gcalendar_*": true,
        "runlayer-gdrive_*": true,
        "runlayer-gdocs_*": true,
        "runlayer-gsheets_*": true
      },
      "permission": {
        "runlayer-g*send*": "ask",
        "runlayer-g*create*": "ask",
        "runlayer-g*update*": "ask",
        "runlayer-g*delete*": "ask",
        "runlayer-g*schedule*": "ask",
        "bash": "deny",
        "skill": "deny"
      }
    },
    "linear": {
      "description": "Reaches Linear via its official remote MCP (OAuth). Dispatched to search and read issues, projects, and documents; write actions (create/update issues, projects, documents) require explicit confirmation. Returns a tight distilled summary, never raw dumps.",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-6",
      "prompt": "{file:./prompts/linear.md}",
      "tools": {
        "linear_*": true
      },
      "permission": {
        "linear_save_*": "ask",
        "bash": "deny",
        "skill": "deny"
      }
    }
  },
  "model": "anthropic/claude-sonnet-5",
  "small_model": "lmstudio/qwen3-30b-a3b-instruct-2507",
  "compaction": {
    "prune": true
  },
  "provider": {
    "anthropic": {
      "models": {
        "claude-opus-4-8": {
          "options": {
            "thinking": {
              "type": "adaptive",
              "display": "summarized"
            }
          }
        },
        "claude-sonnet-5": {
          "options": {
            "thinking": {
              "type": "adaptive",
              "display": "summarized"
            }
          }
        }
      }
    },
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      },
      "models": {
        "qwen3-30b-a3b-instruct-2507": {
          "name": "qwen3-30b-a3b-instruct-2507",
          "limit": {
            "context": 40960,
            "output": 8192
          }
        }
      }
    }
  },
  "tools": {
    "runlayer-zoom_*": false,
    "runlayer-self_*": false,
    "runlayer-slack_*": false,
    "runlayer-atlassian_*": false,
    "github_*": false,
    "runlayer-gmail_*": false,
    "runlayer-gcalendar_*": false,
    "runlayer-gdrive_*": false,
    "runlayer-gdocs_*": false,
    "runlayer-gsheets_*": false,
    "linear_*": false,
    "figma-desktop_*": false,
    "context7_*": false,
    "firefox-devtools_*": false
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "firefox-devtools": {
      "type": "local",
      "command": [
        "npx",
        "@mozilla/firefox-devtools-mcp@0.9.7",
        "--firefox-path",
        "/Applications/Firefox.app/Contents/MacOS/firefox",
        "--enable-script"
      ]
    },
    "runlayer-zoom": {
      "type": "remote",
      "url": "{{ .runlayer.zoom_mcp_url }}"
    },
    "runlayer-self": {
      "type": "remote",
      "url": "{{ .runlayer.self_mcp_url }}"
    },
    "runlayer-slack": {
      "type": "remote",
      "url": "{{ .runlayer.slack_mcp_url }}"
    },
    "runlayer-atlassian": {
      "type": "remote",
      "url": "{{ .runlayer.atlassian_mcp_url }}"
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {{ output "gh" "auth" "token" | trim }}"
      }
    },
    "runlayer-gmail": {
      "type": "remote",
      "url": "{{ .runlayer.gmail_mcp_url }}"
    },
    "runlayer-gcalendar": {
      "type": "remote",
      "url": "{{ .runlayer.gcalendar_mcp_url }}"
    },
    "runlayer-gdrive": {
      "type": "remote",
      "url": "{{ .runlayer.gdrive_mcp_url }}"
    },
    "runlayer-gdocs": {
      "type": "remote",
      "url": "{{ .runlayer.gdocs_mcp_url }}"
    },
    "runlayer-gsheets": {
      "type": "remote",
      "url": "{{ .runlayer.gsheets_mcp_url }}"
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp"
    },
    "figma-desktop": {
      "type": "remote",
      "url": "http://127.0.0.1:3845/mcp",
      "enabled": false
    }
  },
  "formatter": {
    "rubocop": { "disabled": true },
    "ruff": { "disabled": true }
  },
  "lsp": {
    "ruby-lsp": {
      "command": ["ruby", "-S", "ruby-lsp"],
      "extensions": [".rb", ".rake", ".gemspec", ".ru"]
    }
  }
}
