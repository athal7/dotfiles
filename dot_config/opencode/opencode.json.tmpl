{{- /*
opencode.json — OpenCode agent configuration.

Generates ~/.config/opencode/opencode.json via chezmoi. Covers:
  - Model selection (cloud and local via LM Studio)
  - Per-tool permission rules (allow/ask gates for shell commands, git, gh, etc.)
  - MCP server connections
  - Plugin wiring (skill injection, custom commands)
  - Agent-specific permission and skill overrides (lead, plan, build)

Local model setup: LM Studio serves Qwen3 for agentic coding and the kb meeting
pipeline. Install the cask via chezmoi, run `npx lmstudio install-cli`, enable
"Run server on login", and download Qwen 3.5 27B Unsloth UD-IQ3_XXS. Reference
as lmstudio/qwen3.5-27b. See https://www.glukhov.org/ai-devtools/opencode/llms-comparison/
for model benchmarks — use Unsloth quants for patched chat templates.
*/ -}}
{{- /* Universal read-only shell utilities — allowed for all agents */ -}}
{{- $universalReads := dict
  "*" "ask"
  "awk*" "allow"   "gawk*" "allow"  "mawk*" "allow"  "nawk*" "allow"
  "cat*" "allow"   "comm*" "allow"  "cut*" "allow"
  "date*" "allow"  "echo*" "allow"  "false*" "allow" "file*" "allow"
  "grep*" "allow"  "head*" "allow"  "ls*" "allow"
  "printf*" "allow" "pwd*" "allow"  "seq*" "allow"
  "sleep*" "allow"  "sort*" "allow" "source*" "allow" "stat*" "allow"  "tail*" "allow"
  "tr *" "allow"    "tree*" "allow" "true*" "allow"   "uniq*" "allow"
  "wc*" "allow"     "whereis*" "allow" "which*" "allow" "yes*" "allow"
  "find *" "allow"  "find * -delete*" "ask"  "find * -exec*" "ask"
  "find * -execdir*" "ask"  "find * -ok*" "ask"  "find * -okdir*" "ask"
  "sed *" "allow"   "sed -i*" "ask"  "sed --in-place*" "ask"
  "sqlite3 -readonly *" "allow"
  "* --help*" "allow"  "* --version*" "allow"  "* -h" "allow"
-}}
{{- /* Collect per-package patterns from packages.yaml — flat format (pattern: allow/ask) */ -}}
{{- $globalBash := dict -}}
{{- range $list := .packages -}}
  {{- if kindIs "slice" $list -}}
    {{- range $entry := $list -}}
      {{- if kindIs "map" $entry -}}
        {{- $perms := index $entry "permissions" -}}
        {{- if $perms -}}
          {{- $rawName := index $entry "name" | toString -}}
          {{- $cmd := index $entry "command" -}}
          {{- if not $cmd -}}
            {{- $parts := splitList "/" $rawName -}}
            {{- $cmd = last $parts -}}
          {{- end -}}
          {{- range $suffix, $action := $perms -}}
            {{- $pattern := printf "%s %s" $cmd $suffix -}}
            {{- $_ := set $globalBash $pattern $action -}}
          {{- end -}}
        {{- end -}}
      {{- end -}}
    {{- end -}}
  {{- end -}}
{{- end -}}
{{- /* Merge universal reads into global */ -}}
{{- range $p, $action := $universalReads -}}
  {{- $_ := set $globalBash $p $action -}}
{{- end -}}
{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "lead",
  "server": {
    "hostname": "127.0.0.1"
  },
  "plugin": [
    ["./plugins/skill-inject.ts", {
      "architecture": ["gh", "linear", "code-quality"],
      "attention": ["opencode", "ical-cli", "reminders", "gh", "linear"],
      "commit": ["review"],
      "communication": ["knowledge-base"],
      "confluence": [{"skill": "xh", "context": "All requests use xh --ignore-stdin --session=agent for auth"}, "communication"],
      "dictation": ["knowledge-base"],
      "elasticsearch": [{"skill": "xh", "context": "All requests use xh --ignore-stdin --session=agent for auth"}],
      "figma": [{"skill": "xh", "context": "All requests use xh --ignore-stdin --session=agent for auth"}],
      "gh": ["communication"],

      "gws": ["communication"],
      "linear": [{"skill": "xh", "context": "All requests use xh --ignore-stdin --session=agent for auth"}, "communication"],
      "observability": ["elasticsearch"],
      "pagerduty": [{"skill": "xh", "context": "All requests use xh --ignore-stdin --session=agent for auth"}],
      "push": ["commit", "gh", "branching", "linear"],
      "respond-to-review": ["gh", "push", "review", "communication"],
      "review": ["qa", "gh", "linear", "code-quality", "communication"],
      "slack": [{"skill": "xh", "context": "All requests use xh --ignore-stdin --session=agent for auth"}, "communication"]
    }],
    "./plugins/direnv.ts"
  ],
  "permission": {
    "skill": "allow",
    "lsp": "allow",
    "websearch": "allow",
    "external_directory": {
      "*": "ask",
      "~/code/**": "allow",
      "~/.local/share/kb/**": "allow",
      "~/.agents/skills/**": "allow",
      "~/Documents/Zoom/**": "allow",
      "~/Library/Spelling/**": "allow",
      "/tmp/**": "allow"
    },
    "bash": {{ $globalBash | toPrettyJson | indent 4 | trim }}
  },
  {{- /*
  Per-agent skill deny lists — blocked by sst/opencode#21793
  (permission.skill patterns not enforced). When fixed, add to each agent:

  lead:  deny review, respond-to-review (methodology embedded in /implement, /review, /mr commands)
  plan:  deny commit, push, review, respond-to-review, qa, branching, chezmoi
  build: deny commit, push, review, respond-to-review, qa, branching, architecture, thinking-tools
  */ -}}
  "agent": {
    "lead": {
      "mode": "primary",
      "model": "anthropic/claude-opus-4-6",
      "prompt": "{file:./prompts/lead.md}",
      "permission": {
        "task": "allow",
        "edit": "deny",
        "write": "deny"
      }
    },
    "plan": {
      "description": "Deep analysis and architectural thinking subagent. Dispatched by lead for design decisions, complex tradeoffs, and architectural review. Read-only.",
      "mode": "subagent",
      "model": "anthropic/claude-opus-4-6",
      "prompt": "{file:./prompts/plan.md}",
      "permission": {
        "edit": "deny",
        "write": "deny"
      }
    },
    "build": {
      "description": "Focused worker subagent dispatched by lead. Executes implementation work under TDD discipline. Has edit/write access and local dev tooling. Returns a tight summary when done.",
      "mode": "subagent",
      "model": "anthropic/claude-opus-4-6",
      "prompt": "{file:./prompts/build.md}",
      "steps": 30,
      "permission": {
        "edit": "allow",
        "write": "allow",
        "bash": {{ merge (dict "*" "allow") $globalBash | toPrettyJson | indent 8 | trim }}
      }
    }
  },
  "model": "anthropic/claude-opus-4-6",
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      },
      "models": {
        "qwen3.5-27b": {
          "name": "qwen3.5-27b",
          "limit": {
            "context": 32768,
            "output": 8192
          },
          "options": {
            "think": false
          }
        }
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "firefox-devtools": {
      "type": "local",
      "command": [
        "npx",
        "@padenot/firefox-devtools-mcp",
        "--firefox-path",
        "/Applications/Firefox.app/Contents/MacOS/firefox",
        "--profilePath",
        "{{ .chezmoi.homeDir }}/Library/Application Support/Firefox/Profiles/ahjfbe0u.mcp-agent"
      ]
    }
  },
  "formatter": {
    "rubocop": { "disabled": true }
  },
  "lsp": true
}
