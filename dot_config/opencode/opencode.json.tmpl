{{- /*
opencode.json — OpenCode agent configuration.

Generates ~/.config/opencode/opencode.json via chezmoi. Covers:
  - Model selection (cloud and local via LM Studio)
  - Bash permissions: default-allow with curated ask/deny guardrails (system-destructive commands in `$coreGuardrails` here; service-write gates per-tool in packages.yaml)
  - MCP server connections
  - Plugin wiring (skill injection, custom commands)
  - Agent-specific permission and skill overrides (lead, plan, reviewer, qa, build, explore, scout, general)

Local model setup: LM Studio serves Qwen3 for agentic coding and the kb meeting
pipeline. Install the cask via chezmoi, run `npx lmstudio install-cli`, enable
"Run server on login", and download Qwen 3.5 27B Unsloth UD-IQ3_XXS. Reference
as lmstudio/qwen3.5-27b. See https://www.glukhov.org/ai-devtools/opencode/llms-comparison/
for model benchmarks — use Unsloth quants for patched chat templates.
*/ -}}
{{- /* Core guardrails — system-level dangerous commands that must prompt.
       Everything not listed here (and not listed in packages.yaml) is allowed
       by default via the "*": "allow" base. */ -}}
{{- $coreGuardrails := dict
  "rm -rf /*" "ask"   "rm -fr /*" "ask"
  "rm -rf ~*" "ask"   "rm -fr ~*" "ask"
  "rm -rf $HOME*" "ask"
  "sudo *" "ask"
  "dd if=*" "ask"   "dd of=*" "ask"
  "mkfs*" "ask"   "diskutil *" "ask"
  "shutdown*" "ask"   "reboot*" "ask"
  "curl * -X POST*" "ask"   "curl * -X PUT*" "ask"
  "curl * -X DELETE*" "ask"   "curl * -X PATCH*" "ask"
  "curl * -d *" "ask"   "curl * --data*" "ask"
  "curl * -T *" "ask"   "curl * --upload-file*" "ask"
  "wget *" "ask"
-}}
{{- /* Collect per-package patterns from packages.yaml — flat format (pattern: allow/ask) */ -}}
{{- $globalBash := dict -}}
{{- range $list := .packages -}}
  {{- if kindIs "slice" $list -}}
    {{- range $entry := $list -}}
      {{- if kindIs "map" $entry -}}
        {{- $perms := index $entry "permissions" -}}
        {{- if $perms -}}
          {{- range $pattern, $action := $perms -}}
            {{- $_ := set $globalBash $pattern $action -}}
          {{- end -}}
        {{- end -}}
      {{- end -}}
    {{- end -}}
  {{- end -}}
{{- end -}}
{{- /* Merge core guardrails into global */ -}}
{{- range $p, $action := $coreGuardrails -}}
  {{- $_ := set $globalBash $p $action -}}
{{- end -}}
{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "lead",
  "server": {
    "hostname": "127.0.0.1"
  },
  "plugin": [
    ["./lib/skill-inject.ts", {
      "architecture": ["gh", "linear", "code-quality"],
      "attention": ["opencode", "ical-cli", "reminders", "gh", "linear"],
      "communication": ["knowledge-base"],
      "confluence": [{"skill": "xh", "context": "All requests use xh --ignore-stdin --session=agent for auth"}, "communication"],
      "elasticsearch": [{"skill": "xh", "context": "All requests use xh --ignore-stdin --session=agent for auth"}],
      "figma": [{"skill": "xh", "context": "All requests use xh --ignore-stdin --session=agent for auth"}],
      "gh": ["communication"],

      "gws": ["communication"],
      "linear": [{"skill": "xh", "context": "All requests use xh --ignore-stdin --session=agent for auth"}, "communication"],
      "observability": ["elasticsearch"],
      "pagerduty": [{"skill": "xh", "context": "All requests use xh --ignore-stdin --session=agent for auth"}],
      "push": ["commit", "gh", "branching", "linear"],
      "slack": [{"skill": "xh", "context": "All requests use xh --ignore-stdin --session=agent for auth"}, "communication"]
    }]
  ],
  "permission": {
    "skill": "allow",
    "lsp": "allow",
    "websearch": "allow",
    "external_directory": {
      "*": "ask",
      "~/code/**": "allow",
      "~/.local/share/**": "allow",
      "~/.agents/skills/**": "allow",
      "~/Documents/Zoom/**": "allow",
      "/tmp/**": "allow"
    },
    "bash": {{ merge (dict "*" "allow") $globalBash | toPrettyJson | indent 4 | trim }}
  },
  {{- /*
  Per-agent skill deny lists — blocked by sst/opencode#21793
  (permission.skill patterns not enforced). When fixed, add to each agent:

  plan:  deny commit, push, branching, chezmoi
  build: deny commit, push, branching, architecture, thinking-tools
  */ -}}
  "agent": {
    "lead": {
      "mode": "primary",
      "model": "anthropic/claude-sonnet-4-6",
      "prompt": "{file:./prompts/lead.md}",
      "permission": {
        "task": "allow",
        "edit": "deny",
        "write": "deny"
      }
    },
    "plan": {
      "description": "Deep analysis and architectural thinking subagent. Dispatched by lead for design decisions, complex tradeoffs, and architectural review. Read-only.",
      "mode": "subagent",
      "model": "anthropic/claude-opus-4-8",
      "prompt": "{file:./prompts/plan.md}",
      "permission": {
        "edit": "deny",
        "write": "deny"
      }
    },
    "reviewer": {
      "description": "Independent code reviewer — static multi-pass review of a diff, returns/posts classified findings. Opus, independent of the model that wrote the code. UI functional verification is the qa agent's job.",
      "mode": "subagent",
      "model": "anthropic/claude-opus-4-8",
      "prompt": "{file:./prompts/reviewer.md}",
      "permission": {
        "edit": "deny",
        "write": "deny"
      }
    },
    "qa": {
      "description": "Functional QA — drives the running app in a browser (Firefox MCP) to verify UI/behavior. Read-only re: code.",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-6",
      "prompt": "{file:./prompts/qa.md}",
      "permission": {
        "edit": "deny",
        "write": "deny"
      }
    },
    "build": {
      "description": "Focused worker subagent dispatched by lead. Executes implementation work under TDD discipline. Has edit/write access and local dev tooling. Returns a tight summary when done.",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-6",
      "prompt": "{file:./prompts/build.md}",
      "steps": 30,
      "permission": {
        "edit": "allow",
        "write": "allow",
        "bash": {{ merge (dict "*" "allow") $globalBash | toPrettyJson | indent 8 | trim }}
      }
    },
    "explore": {
      "model": "anthropic/claude-sonnet-4-6"
    },
    "scout": {
      "description": "External research — library/framework docs, dependency source, changelogs. Read-only; uses webfetch and context7.",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-6",
      "prompt": "{file:./prompts/scout.md}",
      "permission": {
        "edit": "deny",
        "write": "deny"
      }
    },
    "general": {
      "model": "anthropic/claude-sonnet-4-6"
    }
  },
  "model": "anthropic/claude-opus-4-8",
  "small_model": "anthropic/claude-haiku-4-5",
  "provider": {
    "anthropic": {
      "models": {
        "claude-opus-4-8": {
          "options": {
            "thinking": {
              "type": "adaptive",
              "display": "summarized"
            }
          }
        }
      }
    },
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      },
      "models": {
        "qwen3.5-27b": {
          "name": "qwen3.5-27b",
          "limit": {
            "context": 32768,
            "output": 8192
          },
          "options": {
            "think": false
          }
        }
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "firefox-devtools": {
      "type": "local",
      "command": [
        "npx",
        "@padenot/firefox-devtools-mcp",
        "--firefox-path",
        "/Applications/Firefox.app/Contents/MacOS/firefox"
      ]
    }
  },
  "formatter": {
    "rubocop": { "disabled": true },
    "ruff": { "disabled": true }
  },
  "lsp": true
}
