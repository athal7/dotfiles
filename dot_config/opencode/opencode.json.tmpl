{{- $buildBash := dict -}}
{{- $planBash  := dict -}}
{{- range $list := .packages -}}
  {{- if kindIs "slice" $list -}}
    {{- range $entry := $list -}}
      {{- if kindIs "map" $entry -}}
        {{- $perms := index $entry "permissions" -}}
        {{- if $perms -}}
          {{- range $p := index $perms "ask" }}{{- $_ := set $buildBash $p "ask" -}}{{- end -}}
          {{- range $p := index $perms "allow_reads" -}}
            {{- $_ := set $buildBash $p "allow" -}}
            {{- $_ := set $planBash  $p "allow" -}}
          {{- end -}}
        {{- end -}}
      {{- end -}}
    {{- end -}}
  {{- end -}}
{{- end -}}
{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "instructions": ["tdd.md"],
  "server": {
    "hostname": "127.0.0.1"
  },
  "permission": {
    "skill": "allow",
    "bash": {{ merge (dict "*" "allow" "git push *" "ask" "git -C * push *" "ask" "git push" "ask") $buildBash | toPrettyJson | indent 6 | trim }}
  },
  "agent": {
    "plan": {
      "model": "anthropic/claude-opus-4-7",
      "permission": {
        "bash": {{ merge (dict
          "*" "ask"
          "ls*" "allow"
          "sqlite3 -readonly*" "allow"
          "wc*" "allow"
          "comm*" "allow"
          "sort*" "allow"
          "uniq*" "allow"
          "yq*" "allow"
          "chezmoi diff*" "allow"
          "chezmoi data*" "allow"
          "chezmoi managed*" "allow"
        ) $planBash | toPrettyJson | indent 10 | trim }}
      }
    }
  },
  "model": "anthropic/claude-sonnet-4-6",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3:8b": {
          "name": "qwen3:8b"
        },
        "gemma4:e4b": {
          "name": "gemma4:e4b"
        },
        "gemma4:31b-cloud": {
          "name": "gemma4:31b-cloud"
        },
        "minimax-m2.7:cloud": {
          "name": "minimax-m2.7:cloud"
        },
        "glm-5.1:cloud": {
          "name": "glm-5.1:cloud"
        },
        "kimi:k2.6-cloud": {
          "name": "kimi:k2.6"
        }
      }
    }
  },
  "plugin": [],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "firefox-devtools": {
      "type": "local",
      "command": [
        "npx",
        "@padenot/firefox-devtools-mcp",
        "--firefox-path",
        "/Applications/Firefox Nightly.app/Contents/MacOS/firefox"
      ]
    }
  }
}
