{{- $buildBash := dict -}}
{{- $planBash  := dict -}}
{{- range $list := .packages -}}
  {{- if kindIs "slice" $list -}}
    {{- range $entry := $list -}}
      {{- if kindIs "map" $entry -}}
        {{- $perms := index $entry "permissions" -}}
        {{- if $perms -}}
          {{- range $p := index $perms "ask" }}{{- $_ := set $buildBash $p "ask" -}}{{- end -}}
          {{- range $p := index $perms "allow_reads" -}}
            {{- $_ := set $buildBash $p "allow" -}}
            {{- $_ := set $planBash  $p "allow" -}}
          {{- end -}}
        {{- end -}}
      {{- end -}}
    {{- end -}}
  {{- end -}}
{{- end -}}
{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "instructions": ["tdd.md"],
  "server": {
    "hostname": "127.0.0.1"
  },
  "permission": {
    "skill": "allow",
    "bash": {{ merge (dict "*" "allow" "git push *" "ask" "git -C * push *" "ask" "git push" "ask") $buildBash | toPrettyJson | indent 6 | trim }}
  },
  "agent": {
    "plan": {
      "model": "anthropic/claude-opus-4-7",
      "permission": {
        "bash": {{ merge (dict
          "*" "ask"
          "ls*" "allow"
          "sqlite3 -readonly*" "allow"
          "wc*" "allow"
          "comm*" "allow"
          "sort*" "allow"
          "uniq*" "allow"
          "head*" "allow"
          "tail*" "allow"
          "grep*" "allow"
          "cat*" "allow"
          "yq*" "allow"
        ) $planBash | toPrettyJson | indent 10 | trim }}
      }
    },
    "local-build": {
      "description": "Build-mode agent slimmed for local models — denies MCP tools (firefox-devtools, context7) and subagent delegation to cut ~25KB / ~7k tokens off the system prompt. The build agent's default prompt is sized for Sonnet/Opus; on a smaller local model prompt eval is the bottleneck. Edits are allowed without prompting because the local model is sandboxed by its own limited tool set and the user is expected to review work in this agent rather than gate each tool. Model: Qwen 3.5 27B (Unsloth UD-IQ3_XXS) — Glukhov's top empirical pick for OpenCode local (5.0% error rate; see README).",
      "mode": "primary",
      "model": "lmstudio/qwen3.5-27b",
      "permission": {
        "firefox-devtools_*": "deny",
        "context7_*": "deny",
        "task": "deny",
        "edit": "allow",
        "write": "allow",
        "bash": {
          "*": "ask",
          "ls*": "allow",
          "cat*": "allow",
          "head*": "allow",
          "tail*": "allow",
          "grep*": "allow",
          "rg*": "allow",
          "find*": "allow",
          "wc*": "allow"
        }
      }
    }
  },
  "model": "anthropic/claude-sonnet-4-6",
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      },
      "models": {
        "qwen3.5-27b": {
          "name": "qwen3.5-27b",
          "limit": {
            "context": 32768,
            "output": 8192
          },
          "options": {
            "think": false
          }
        }
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "gemma4:e4b": {
          "name": "gemma4:e4b",
          "limit": {
            "context": 8192,
            "output": 2048
          }
        },
        "gemma4:31b-cloud": {
          "name": "gemma4:31b-cloud"
        },
        "minimax-m2.7:cloud": {
          "name": "minimax-m2.7:cloud"
        },
        "glm-5.1:cloud": {
          "name": "glm-5.1:cloud"
        },
        "kimi:k2.6-cloud": {
          "name": "kimi:k2.6"
        }
      }
    }
  },
  "plugin": [],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "firefox-devtools": {
      "type": "local",
      "command": [
        "npx",
        "@padenot/firefox-devtools-mcp",
        "--firefox-path",
        "/Applications/Firefox Nightly.app/Contents/MacOS/firefox"
      ]
    }
  }
}
