{{- $buildBash := dict -}}
{{- range $list := .packages -}}
  {{- if kindIs "slice" $list -}}
    {{- range $entry := $list -}}
      {{- if kindIs "map" $entry -}}
        {{- $perms := index $entry "permissions" -}}
        {{- if $perms -}}
          {{- $denyBuild := index $perms "build" -}}
          {{- if eq $denyBuild "deny" -}}
            {{- $rawName := index $entry "name" | toString -}}
            {{- $cmd := index $entry "command" -}}
            {{- if not $cmd -}}
              {{- $parts := splitList "/" $rawName -}}
              {{- $cmd = last $parts -}}
            {{- end -}}
            {{- $denyPattern := printf "%s *" $cmd -}}
            {{- $_ := set $buildBash $denyPattern "deny" -}}
            {{- range $suffix := index $perms "always_allow" -}}
              {{- $allowPattern := printf "%s %s*" $cmd $suffix -}}
              {{- $_ := set $buildBash $allowPattern "allow" -}}
            {{- end -}}
          {{- end -}}
        {{- end -}}
      {{- end -}}
    {{- end -}}
  {{- end -}}
{{- end -}}
{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "lead",
  "server": {
    "hostname": "127.0.0.1"
  },
  "permission": {
    "skill": "allow",
    "bash": {
      "*": "ask"
    }
  },
  "agent": {
    "lead": {
      "mode": "primary",
      "model": "anthropic/claude-sonnet-4-6",
      "prompt": "{file:./prompts/lead.md}",
      "permission": {
        "task": "allow",
        "bash": {
          "*": "ask"
        }
      }
    },
    "plan": {
      "description": "Deep analysis and architectural thinking subagent. Dispatched by lead for design decisions, complex tradeoffs, and architectural review. Read-only.",
      "mode": "subagent",
      "model": "anthropic/claude-opus-4-7",
      "prompt": "{file:./prompts/plan.md}",
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "ask"
        }
      }
    },
    "build": {
      "description": "Focused worker subagent dispatched by lead. Executes implementation work under TDD discipline. Has edit/write access and local dev tooling (test runners, linters, formatters, read-only git). Denied from service writes (gh, linear, confluence, ical, remindctl) and git workflow operations (commit, push, rebase, checkout, etc.) via per-package agents.build.deny rules. Returns a tight summary when done.",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-6",
      "prompt": "{file:./prompts/build.md}",
      "steps": 30,
      "permission": {
        "edit": "allow",
        "write": "allow",
        "bash": {{ merge (dict
          "*" "allow"
        ) $buildBash | toPrettyJson | indent 10 | trim }}
      }
    }
  },
  "command": {
    "review": {
      "description": "review changes [commit|branch|pr|staged], defaults to uncommitted",
      "agent": "lead",
      "subtask": true,
      "template": "Load your `review` skill, then review the following target: $ARGUMENTS\n\nIf $ARGUMENTS is empty, review uncommitted changes. If it looks like a PR number/URL, branch name, or commit SHA, route accordingly per the skill's instructions. Apply the tone rules from your global AGENTS.md when writing findings."
    }
  },
  "model": "anthropic/claude-sonnet-4-6",
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      },
      "models": {
        "qwen3.5-27b": {
          "name": "qwen3.5-27b",
          "limit": {
            "context": 32768,
            "output": 8192
          },
          "options": {
            "think": false
          }
        }
      }
    }
  },
  "plugin": [],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "firefox-devtools": {
      "type": "local",
      "command": [
        "npx",
        "@padenot/firefox-devtools-mcp",
        "--firefox-path",
        "/Applications/Firefox Nightly.app/Contents/MacOS/firefox"
      ]
    }
  }
}
