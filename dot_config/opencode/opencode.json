{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [],
  "server": {
    "hostname": "127.0.0.1"
  },
  "permission": {
    "skill": "allow"
  },
  "model": "anthropic/claude-sonnet-4-6",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3:8b": {
          "name": "qwen3:8b"
        },
        "gemma4:e4b": {
          "name": "gemma4:e4b"
        },
        "gemma4:31b-cloud": {
          "name": "gemma4:31b-cloud"
        },
        "minimax-m2.7:cloud": {
          "name": "minimax-m2.7:cloud"
        },
        "glm-5.1:cloud": {
          "name": "glm-5.1:cloud"
        },
        "kimi:k2.6-cloud": {
          "name": "kimi:k2.6"
        }
      }
    }
  },
  "formatter": {
    "rubocop": {
      "disabled": true
    }
  },
  "plugin": [
    "opencode-pty@^0.1"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "firefox-devtools": {
      "type": "local",
      "command": [
        "npx",
        "@padenot/firefox-devtools-mcp",
        "--firefox-path",
        "/Applications/Firefox Nightly.app/Contents/MacOS/firefox"
      ]
    }
  }
}
