{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [],
  "server": {
    "hostname": "127.0.0.1"
  },
  "permission": {
    "skill": "allow"
  },
  "model": "anthropic/claude-sonnet-4-6",
  "agent": {
    "expert": {
      "model": "anthropic/claude-opus-4-6",
      "temperature": 0
    }
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3-coder": {
          "name": "qwen3-coder"
        }
      }
    },
    "opencode": {
      "models": {
        "big-pickle": {
          "name": "pickle"
        }
      }
    },
    "anthropic": {
      "models": {
        "claude-opus-4-6": {
          "name": "opus"
        },
        "claude-sonnet-4-6": {
          "name": "sonnet"
        },
        "claude-haiku-4-5": {
          "name": "haiku"
        }
      }
    }
  },
  "formatter": {
    "rubocop": {
      "disabled": true
    }
  },
  "plugin": [
    "opencode-pty@^0.1",
    "opencode-wakatime@^1.2"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "minutes": {
      "type": "local",
      "command": ["npx", "minutes-mcp"]
    },
    "firefox-devtools": {
      "type": "local",
      "command": [
        "npx",
        "@padenot/firefox-devtools-mcp",
        "--firefox-path",
        "/Applications/Firefox Nightly.app/Contents/MacOS/firefox"
      ]
    }
  }
}
