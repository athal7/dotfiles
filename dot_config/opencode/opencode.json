{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [],
  "server": {
    "hostname": "127.0.0.1"
  },
  "permission": {
    "skill": "allow"
  },
  "model": "anthropic/claude-haiku-4-5",
  "agent": {
    "plan": {
      "textVerbosity": "low",
      "temperature": 0.3,
      "permission": {
        "bash": {
          "*": "deny",
          "git *": "allow",
          "gh pr *": "allow",
          "gh issue *": "allow",
          "gh api *": "allow",
          "gh repo view *": "allow",
          "gh search *": "allow"
        },
        "task": {
          "*": "allow"
        }
      }
    },
    "build": {
      "model": "anthropic/claude-sonnet-4-6"
    },
    "expert": {
      "model": "anthropic/claude-opus-4-6",
      "temperature": 0
    }
  },
  "provider": {
    "github-copilot": {
      "options": {
        "headers": {
          "Authorization": "Bearer {auth:github-copilot.access}"
        }
      },
      "models": {
        "gpt-4.1": {
          "name": "gpt-4.1"
        },
        "gpt-5-mini": {
          "name": "gpt-5-mini"
        }
      }
    },
    "opencode": {
      "models": {
        "big-pickle": {
          "name": "pickle"
        }
      }
    },
    "anthropic": {
      "models": {
        "claude-opus-4-6": {
          "name": "opus"
        },
        "claude-sonnet-4-6": {
          "name": "sonnet"
        },
        "claude-haiku-4-5": {
          "name": "haiku"
        }
      }
    }
  },
  "formatter": {
    "rubocop": {
      "disabled": true
    }
  },
  "plugin": [
    "opencode-pty@^0.1",
    "opencode-wakatime@^1.2"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "minutes": {
      "type": "local",
      "command": ["npx", "minutes-mcp"]
    },
    "firefox-devtools": {
      "type": "local",
      "command": [
        "npx",
        "@padenot/firefox-devtools-mcp",
        "--firefox-path",
        "/Applications/Firefox Nightly.app/Contents/MacOS/firefox"
      ]
    }
  }
}
