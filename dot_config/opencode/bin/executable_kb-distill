#!/bin/sh
# Distill a Zoom meeting transcript into structured JSON facts via the local
# LM Studio model. Pure text-in -> JSON-facts-out primitive: this helper does
# NO knowledge-base writes and NO orchestration. The caller (the /kb-enrich
# lead agent) keeps all writes and, on ANY non-zero exit here, falls back to
# reading the raw transcript itself for full fidelity.
#
# Usage: kb-distill <caption-file|-> ["Meeting Title"] ["YYYY-MM-DD"]
#
# Exit codes (any non-zero => caller falls back to Claude reading raw):
#   0  ok            JSON array of per-chunk fact objects on stdout
#   2  usage         missing/!bad args
#   3  unavailable   LM Studio endpoint/model unreachable (could not warm)
#   4  crashed       model crash (HTTP 400 / .error) unrecoverable after re-warm
#   5  degraded      partial result: some chunk(s) could not be distilled
#
# The transcript is sent ONLY to the on-device local model (privacy positive);
# the authoritative do-not-store privacy filter still applies later at the
# /kb-enrich WRITE step, not here.

set -eu

ENDPOINT="http://127.0.0.1:1234/v1/chat/completions"
MODELS_URL="http://127.0.0.1:1234/v1/models"
MODEL="qwen3-30b-a3b-instruct-2507"
# lms is NOT on the kb-enrich LaunchAgent PATH; resolve by absolute path.
LMS="$HOME/.lmstudio/bin/lms"

# Chunk budget: JIT default context is 8192 tokens. Reserve ~700 for the
# system+schema prompt and ~800 for output (max_tokens), leaving ~6600 usable;
# a 4000-token (~16 KB) chunk leaves comfortable headroom. Most transcripts are
# a single chunk. (FUTURE optimization, UNPROVEN: a single-pass 40960-ctx load
# via `lms load -c 40960` would avoid chunking, but that context size CRASHED
# the model live -- HTTP 400 "model has crashed", auto-unload -- so we stay on
# the JIT 8192 default plus chunking here.)
CHUNK_BYTES=16000

SYSTEM='You extract structured facts from meeting transcripts. Output ONLY one valid minified JSON object matching the schema. No prose, no markdown, no code fences. Do not include any health, compensation, performance-review, legal/privileged, or HR content. If a field has no data, use an empty array or empty string.'
SCHEMA='{"participants":[string],"topics":[string],"decisions":[string],"action_items":[{"who":string,"what":string,"due":string}],"open_questions":[string],"summary":string}'

usage() {
  echo "usage: kb-distill <caption-file|-> [\"Meeting Title\"] [\"YYYY-MM-DD\"]" >&2
  exit 2
}

# ---- 1. args -------------------------------------------------------------
[ "$#" -ge 1 ] || usage
SRC="$1"
TITLE="${2:-}"
DATE="${3:-}"

WORK="$(mktemp -d "${TMPDIR:-/tmp}/kb-distill.XXXXXX")" || { echo "kb-distill: mktemp failed" >&2; exit 4; }
trap 'rm -rf "$WORK"' EXIT INT TERM

TRANSCRIPT="$WORK/transcript.txt"
if [ "$SRC" = "-" ]; then
  cat > "$TRANSCRIPT"
else
  [ -f "$SRC" ] || { echo "kb-distill: caption file not found: $SRC" >&2; exit 2; }
  cat "$SRC" > "$TRANSCRIPT"
fi
[ -s "$TRANSCRIPT" ] || { echo "kb-distill: empty transcript" >&2; exit 2; }

# ---- 2. preflight + warm -------------------------------------------------
model_ready() {
  curl -s -m 5 "$MODELS_URL" 2>/dev/null \
    | jq -e --arg m "$MODEL" '.data[]|select(.id==$m)' >/dev/null 2>&1
}

warm() {
  # Only attempt if the lms binary exists. `timeout` is GNU coreutils and is NOT
  # present on macOS nor on the LaunchAgent PATH, so we bound the load ourselves:
  # launch `lms load` in the background and poll model_ready against a hard ~30s
  # deadline. Warm at the safe JIT context (8192), never 40960.
  # Always returns 0: warming is best-effort, and a non-zero return from a bare
  # call would trip `set -e` and abort before the caller can re-check / exit 3.
  if [ -x "$LMS" ]; then
    "$LMS" load "$MODEL" -c 8192 --ttl 3600 -y >/dev/null 2>&1 &
    _load_pid=$!
    _i=0
    while [ "$_i" -lt 15 ]; do
      if model_ready; then
        kill "$_load_pid" 2>/dev/null || true
        return 0
      fi
      sleep 2
      _i=$((_i + 1))
    done
    kill "$_load_pid" 2>/dev/null || true
  fi
  return 0
}

if ! model_ready; then
  warm
  if ! model_ready; then
    echo "kb-distill: LM Studio model '$MODEL' unavailable at $MODELS_URL" >&2
    exit 3
  fi
fi

# ---- 3. chunk on speaker-block boundaries --------------------------------
# Speaker markers look like "[Speaker 00:01:23]" / "[Alex 00:01:23]". Split so
# each chunk starts on such a marker and stays <= CHUNK_BYTES; if no markers are
# present, fall back to paragraph/line boundaries via the same size cap. Chunk
# files are written as chunk.000, chunk.001, ...
SPEAKER_RE='^\[[^]]*[0-9][0-9]:[0-9][0-9]:[0-9][0-9][^]]*\]'

# SPEAKER_RE is passed via the environment (ENVIRON), NOT `-v`: awk's `-v`
# assignment runs backslash escape-processing, which would collapse the `\[`/`\]`
# in the marker pattern and silently break the match. ENVIRON keeps it verbatim.
SPEAKER_RE="$SPEAKER_RE" awk -v max="$CHUNK_BYTES" -v dir="$WORK" '
  BEGIN { near = (max * 7) / 10; re = ENVIRON["SPEAKER_RE"] }   # near: 70% soft cap
  function flush() {
    if (buf == "") return
    fn = sprintf("%s/chunk.%03d", dir, n)
    printf "%s", buf > fn
    close(fn)
    n++
    buf = ""
    sz = 0
  }
  {
    line = $0 "\n"
    llen = length(line)
    is_marker = ($0 ~ re)
    # Prefer splitting AT a speaker marker once the open chunk is near the cap
    # (keeps speaker blocks intact); otherwise hard-split when a single line
    # would overflow the open chunk.
    if (buf != "" && ((is_marker && sz >= near) || (sz + llen > max))) flush()
    buf = buf line
    sz += llen
  }
  END { flush(); print n }
' "$TRANSCRIPT" > "$WORK/nchunks"

NCHUNKS="$(cat "$WORK/nchunks")"
[ "$NCHUNKS" -ge 1 ] || { echo "kb-distill: no chunks produced" >&2; exit 2; }

# ---- 4. per-chunk distill ------------------------------------------------
# Build the request body for a given chunk file via jq (safe JSON encoding of
# arbitrary transcript text). max_tokens 800, temperature 0 for stability
# (idempotency does NOT rely on bit-reproducibility), stream false.
build_body() {
  _chunk="$1"
  jq -n --rawfile chunk "$_chunk" \
        --arg model "$MODEL" --arg system "$SYSTEM" --arg schema "$SCHEMA" \
        --arg title "$TITLE" --arg date "$DATE" \
    '{
      model: $model, temperature: 0, max_tokens: 800, stream: false,
      messages: [
        {role:"system", content:$system},
        {role:"user", content:
          ("Schema: " + $schema +
           "\nMeeting title: " + $title +
           "\nMeeting date: " + $date +
           "\nTranscript chunk:\n" + $chunk)}
      ]
    }'
}

# POST a body file, write raw response to $WORK/resp. Returns curl exit status.
post() {
  curl -s -m 90 -X POST "$ENDPOINT" \
    -H 'Content-Type: application/json' \
    --data-binary "@$1" > "$WORK/resp" 2>/dev/null
}

# Classify the response in $WORK/resp. Echoes one of: ok|length|empty|crash.
# On ok, the parsed JSON content is left in $WORK/content.
classify() {
  if jq -e '.error' "$WORK/resp" >/dev/null 2>&1; then
    echo crash; return
  fi
  fr="$(jq -r '.choices[0].finish_reason // empty' "$WORK/resp" 2>/dev/null || true)"
  jq -r '.choices[0].message.content // empty' "$WORK/resp" > "$WORK/content" 2>/dev/null || true
  if [ ! -s "$WORK/content" ]; then echo empty; return; fi
  if [ "$fr" = "length" ]; then echo length; return; fi
  if ! jq -e . "$WORK/content" >/dev/null 2>&1; then echo empty; return; fi
  echo ok
}

# Distill a single chunk file. On success prints minified JSON object to stdout
# and returns 0. Returns 1 if degraded (unusable after retry), 2 if the model
# crashed unrecoverably.
distill_chunk() {
  cf="$1"
  attempt=0
  last=transport
  while [ "$attempt" -le 2 ]; do
    attempt=$((attempt + 1))
    build_body "$cf" > "$WORK/body"
    if ! post "$WORK/body"; then
      # transport/timeout failure: retry up to the cap
      last=transport
      continue
    fi
    last="$(classify)"
    case "$last" in
      ok)
        jq -c . "$WORK/content"
        return 0
        ;;
      crash)
        # HTTP 400 / .error => model crash. Re-warm and retry once more.
        warm
        continue
        ;;
      length|empty)
        # Output-budget exhaustion or intermittent empty: split chunk in half
        # and distill each half, concatenating their objects.
        half="$(( $(wc -c < "$cf") / 2 ))"
        [ "$half" -ge 1 ] || return 1
        head -c "$half" "$cf" > "$WORK/half.a"
        tail -c +"$((half + 1))" "$cf" > "$WORK/half.b"
        # Only split once (halves are distilled non-recursively to bound work).
        # N1: the half-retry path does NOT retry transport failures (`post ||
        # true` then classify) -- this bounds the work; a failed half simply
        # degrades rather than re-entering the retry loop.
        a_ok=0; b_ok=0
        build_body "$WORK/half.a" > "$WORK/body"; post "$WORK/body" || true
        if [ "$(classify)" = ok ]; then cp "$WORK/content" "$WORK/obj.a"; a_ok=1; fi
        build_body "$WORK/half.b" > "$WORK/body"; post "$WORK/body" || true
        if [ "$(classify)" = ok ]; then cp "$WORK/content" "$WORK/obj.b"; b_ok=1; fi
        if [ "$a_ok" = 1 ] && [ "$b_ok" = 1 ]; then
          jq -c . "$WORK/obj.a"; jq -c . "$WORK/obj.b"
          return 0
        elif [ "$a_ok" = 1 ]; then
          jq -c . "$WORK/obj.a"; return 0
        elif [ "$b_ok" = 1 ]; then
          jq -c . "$WORK/obj.b"; return 0
        fi
        # N2: a model crash surfacing inside this split-retry is intentionally
        # downgraded to degraded (return 1 => exit 5), not exit 4. Exit 4 is
        # reserved for the primary attempt loop's persistent crash; here any
        # non-zero already triggers the caller's raw-transcript fallback.
        return 1
        ;;
    esac
  done
  # Retries exhausted. A persistent crash is unrecoverable (caller exit 4);
  # anything else is merely degraded (caller exit 5).
  [ "$last" = crash ] && return 2
  return 1
}

# ---- 5. reduce: emit a JSON array, one element per chunk -----------------
# Cross-chunk MERGE is intentionally deferred to the caller (Claude), NOT done
# by a second local call. We just collect each chunk's object(s).
OBJECTS="$WORK/objects.ndjson"
: > "$OBJECTS"
DEGRADED=0
i=0
while [ "$i" -lt "$NCHUNKS" ]; do
  cf="$(printf '%s/chunk.%03d' "$WORK" "$i")"
  if out="$(distill_chunk "$cf")"; then
    printf '%s\n' "$out" >> "$OBJECTS"
  else
    rc=$?
    if [ "$rc" = 2 ]; then
      echo "kb-distill: model crashed and did not recover" >&2
      exit 4
    fi
    DEGRADED=1
    echo "kb-distill: chunk $i degraded (could not distill)" >&2
  fi
  i=$((i + 1))
done

# Assemble all collected objects (possibly >NCHUNKS after a split) into one
# JSON array on stdout.
jq -s -c '.' "$OBJECTS"

# ---- 6. exit -------------------------------------------------------------
if [ "$DEGRADED" = 1 ]; then
  exit 5
fi
exit 0
