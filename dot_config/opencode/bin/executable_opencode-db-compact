#!/usr/bin/env bash
# opencode-db-compact — ONE-TIME, standalone, exclusive-lock compaction of the
# opencode SQLite DB. This is the only script here that requires exclusive
# access: it flips auto_vacuum to INCREMENTAL and runs a full VACUUM (which
# rewrites the whole file). After this runs once, the recurring
# opencode-cleanup --db can reclaim space cheaply via PRAGMA incremental_vacuum.
#
# NEVER scheduled as a recurring agent and NEVER called by the orchestrator.
# Run it by hand, once, when you want to physically shrink the file.
#
# There is no persistent daemon and no Desktop app anymore, so there is no
# "managed" process this script is allowed to stop on your behalf. Any
# opencode process holding the DB open — a TUI running in an aoe tmux pane, a
# hand-started `opencode`, a hand-started `opencode serve`, whatever — is
# treated uniformly as a live holder that blocks compaction. This script never
# stops anything itself; it refuses and asks the human to stop the session.
#
# Procedure:
#   0. idempotent guard — already INCREMENTAL with a small freelist => exit 0
#   1. refuse if ANY process holds the DB open. We inspect the actual holders
#      of opencode.db via lsof and resolve each PID's command line — every
#      resolved PID is a live holder, no exemptions. Proceeding while
#      something holds the file open would either make VACUUM fail or hang.
#      The human must stop the session (Ctrl-C the TUI / quit the process).
#   2. wal_checkpoint(TRUNCATE) + auto_vacuum=INCREMENTAL + VACUUM
#   3. report before/after page_count
#
# This file is BOTH an executable and a sourceable library: the test suite
# sources it with CLEANUP_LIB=1 to unit-test the live-holder classifier
# (db_live_holders) by overriding db_holder_pids / db_pid_command — without a
# live process — mirroring how opencode-db-maintain is made sourceable.
#
# Usage: opencode-db-compact [--dry-run] [--force]

set -euo pipefail

OPENCODE_DB="${OPENCODE_DB:-$HOME/.local/share/opencode/opencode.db}"
FREELIST_OK_MAX="${COMPACT_FREELIST_OK_MAX:-1000}"

db_pragma() { sqlite3 "$OPENCODE_DB" "PRAGMA $1;" 2>/dev/null || echo ""; }

# Enumerate the PIDs that currently hold the DB file open. Overridable in tests
# (redefine after sourcing with CLEANUP_LIB=1) to feed synthetic holders.
db_holder_pids() {
	lsof -t -- "$OPENCODE_DB" 2>/dev/null || true
}

# Echo the full command line for a PID. Overridable in tests.
db_pid_command() {
	ps -o command= -p "$1" 2>/dev/null || true
}

# Classify the DB holders. Reads holder PIDs from db_holder_pids and, for each,
# its command line from db_pid_command. Echoes one "<pid>\t<command>" line for
# every live holder — every PID that resolves to a non-empty command line.
# Already-gone PIDs (empty command) are omitted. Empty output => safe to
# proceed.
db_live_holders() {
	local pid cmd
	while IFS= read -r pid; do
		[ -n "$pid" ] || continue
		cmd="$(db_pid_command "$pid")"
		[ -n "$cmd" ] || continue
		printf '%s\t%s\n' "$pid" "$cmd"
	done < <(db_holder_pids)
}

db_compact_main() {
	local dry_run=0 force=0 arg
	for arg in "$@"; do
		case "$arg" in
			--dry-run) dry_run=1 ;;
			--force) force=1 ;;
			-h|--help) echo "usage: opencode-db-compact [--dry-run] [--force]"; return 0 ;;
			*) echo "db-compact: unknown argument: $arg" >&2; return 2 ;;
		esac
	done

	[ -f "$OPENCODE_DB" ] || { echo "db-compact: database not found: $OPENCODE_DB" >&2; return 1; }

	local auto_vacuum freelist page_count page_size
	auto_vacuum="$(db_pragma auto_vacuum)"      # 0=NONE 1=FULL 2=INCREMENTAL
	freelist="$(db_pragma freelist_count)"
	page_count="$(db_pragma page_count)"
	page_size="$(db_pragma page_size)"
	freelist="${freelist:-0}"; auto_vacuum="${auto_vacuum:-0}"
	page_count="${page_count:-0}"; page_size="${page_size:-0}"

	echo "db-compact: $OPENCODE_DB"
	echo "  auto_vacuum=$auto_vacuum freelist_count=$freelist page_count=$page_count page_size=$page_size"

	# --- (0) idempotent guard.
	if [ "$auto_vacuum" = "2" ] && [ "$freelist" -le "$FREELIST_OK_MAX" ]; then
		echo "Already INCREMENTAL with a small freelist ($freelist <= $FREELIST_OK_MAX). Nothing to do."
		return 0
	fi

	# Classify the live holders of the DB once, up front.
	local holders
	holders="$(db_live_holders)"

	if [ "$dry_run" -eq 1 ]; then
		echo "(dry-run) Plan:"
		echo "  1. refuse if ANY process holds the DB open (TUI / opencode serve / etc.)"
		echo "  2. sqlite3: wal_checkpoint(TRUNCATE); auto_vacuum=INCREMENTAL; VACUUM"
		echo "  3. report before/after page_count"
		if [ -n "$holders" ]; then
			echo "  WOULD REFUSE: live holder(s) of $OPENCODE_DB detected:"
			printf '%s\n' "$holders" | while IFS=$'\t' read -r p c; do echo "    pid $p: $c"; done
			echo "  -> stop the opencode session (Ctrl-C the TUI / quit the process) and retry."
		else
			echo "  holders: none — would proceed."
		fi
		echo "  current: auto_vacuum=$auto_vacuum freelist=$freelist page_count=$page_count"
		return 0
	fi

	# --- (1) refuse if any process holds the DB.
	if [ -n "$holders" ]; then
		echo "ERROR: an opencode process is holding $OPENCODE_DB open — stop it (Ctrl-C the" >&2
		echo "       TUI / quit the process) and retry. We will not stop it for you." >&2
		echo "       Live holder(s):" >&2
		printf '%s\n' "$holders" | while IFS=$'\t' read -r p c; do echo "         pid $p: $c" >&2; done
		return 1
	fi

	if [ "$force" -ne 1 ]; then
		if [ -t 0 ]; then
			local ans
			read -r -p "This VACUUMs the DB exclusively (brief unavailability while it runs). Proceed? [y/N] " ans
			case "$ans" in y|Y|yes|YES) ;; *) echo "aborted."; return 0 ;; esac
		else
			echo "non-interactive and --force not given; aborting." >&2; return 1
		fi
	fi

	# --- (2) compact.
	local before after
	before="$page_count"
	echo "Compacting (wal_checkpoint TRUNCATE; auto_vacuum=INCREMENTAL; VACUUM) ..."
	sqlite3 "$OPENCODE_DB" "PRAGMA wal_checkpoint(TRUNCATE); PRAGMA auto_vacuum=INCREMENTAL; VACUUM;"
	after="$(db_pragma page_count)"; after="${after:-0}"

	# --- (3) report.
	echo "Done. page_count: $before -> $after (auto_vacuum now $(db_pragma auto_vacuum))."
}

# CLI entrypoint (skipped when sourced as a library with CLEANUP_LIB=1).
if [ "${CLEANUP_LIB:-0}" != "1" ]; then
	db_compact_main "$@"
fi
