#!/usr/bin/env python3
# chezmoi modify script — merges desired config into existing ~/.homebridge/config.json
# Reads current file from stdin, writes merged result to stdout.

import json
import sys

config = json.load(sys.stdin)

# Ensure platforms list exists
config.setdefault("platforms", [])

# Drop the legacy unofficial-API platform (migrated to the official Google SDM plugin)
config["platforms"] = [p for p in config["platforms"] if p.get("platform") != "NestAccfactory"]

# Find or create the homebridge-google-nest-sdm platform entry
sdm = next((p for p in config["platforms"] if p.get("platform") == "homebridge-google-nest-sdm"), None)
if sdm is None:
    sdm = {"platform": "homebridge-google-nest-sdm"}
    config["platforms"].insert(0, sdm)

# Scaffold required credential fields with empty-string defaults.
# setdefault preserves any real values already present in the deployed config —
# secrets live only in ~/.homebridge/config.json, never in this public repo.
for field in ("clientId", "clientSecret", "projectId", "refreshToken", "subscriptionId"):
    sdm.setdefault(field, "")

# Ensure homebridge-config-ui-x is present
config_ui = next((p for p in config["platforms"] if p.get("platform") == "config"), None)
if config_ui is None:
    config["platforms"].append({"name": "Config", "port": 8581, "platform": "config"})

print(json.dumps(config, indent=2))
