#!/bin/bash
# Clean old browser versions from Playwright and Selenium caches
# Keeps only the latest version of each browser type to prevent accumulation

# --- Playwright ---
PLAYWRIGHT_DIR="$HOME/Library/Caches/ms-playwright"

if [ -d "$PLAYWRIGHT_DIR" ]; then
  for browser_type in chromium chromium_headless_shell firefox webkit; do
    versions=$(ls -d "$PLAYWRIGHT_DIR/$browser_type"-* 2>/dev/null | sort -V -r | tail -n +2)
    if [ -n "$versions" ]; then
      echo "Playwright: cleaning old $browser_type versions..."
      echo "$versions" | xargs rm -rf
    fi
  done
  echo "Playwright browser cache cleanup complete"
fi

# --- Selenium Manager ---
SELENIUM_DIR="$HOME/.cache/selenium"

if [ -d "$SELENIUM_DIR" ]; then
  for browser in chrome chrome-headless-shell firefox; do
    browser_dir="$SELENIUM_DIR/$browser"
    [ -d "$browser_dir" ] || continue
    for platform_dir in "$browser_dir"/*/; do
      [ -d "$platform_dir" ] || continue
      versions=$(ls -d "$platform_dir"*/ 2>/dev/null | sort -V -r | tail -n +2)
      if [ -n "$versions" ]; then
        echo "Selenium: cleaning old $browser versions in $(basename "$platform_dir")..."
        echo "$versions" | xargs rm -rf
      fi
    done
  done
  echo "Selenium browser cache cleanup complete"
fi
