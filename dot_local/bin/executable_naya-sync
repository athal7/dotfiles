#!/bin/sh
# Sync NayaFlow profile DB between main and beta apps, then re-add to chezmoi.
# Triggered by launchd WatchPaths on both DB files.

MAIN="$HOME/Library/Application Support/NayaFlow/user-data.db"
BETA="$HOME/Library/Application Support/NayaFlow-Beta/user-data-beta.db"

[ -f "$MAIN" ] || [ -f "$BETA" ] || exit 0

if [ -f "$BETA" ] && [ "$BETA" -nt "$MAIN" ]; then
  cp "$BETA" "$MAIN"
  echo "$(date): Copied beta → main"
elif [ -f "$MAIN" ] && [ "$MAIN" -nt "$BETA" ]; then
  cp "$MAIN" "$BETA"
  echo "$(date): Copied main → beta"
fi

chezmoi re-add "$MAIN"
echo "$(date): chezmoi re-add done"

SOURCE_DIR="$(chezmoi source-path)"
if [ -z "$SOURCE_DIR" ] || [ ! -d "$SOURCE_DIR/.git" ]; then
  echo "$(date): chezmoi source-path unavailable or not a git repo, aborting" >&2
  exit 1
fi
cd "$SOURCE_DIR" || exit 1
if ! git diff --quiet || ! git diff --cached --quiet; then
  git add -A
  if git commit -m "chore: sync NayaFlow DB [$(date '+%Y-%m-%d')]"; then
    echo "$(date): git commit done"
  else
    echo "$(date): git commit failed" >&2
  fi
fi
