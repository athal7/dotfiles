#!/usr/bin/env bash
# aoe-pick-reminder — narrow to a scope (today/overdue/week/all-open/a
# specific list), fuzzy-pick an open macOS Reminder within that scope via
# gum, and copy a formatted payload (including the exact `remindctl complete
# <id>` command to mark it done) to the clipboard for pasting into a new aoe
# session.

set -euo pipefail

# Stage 1: narrow scope down to a JSON array of reminders before handing off
# to the existing fuzzy-picker stage below. Keeps "just search everything"
# available as "All open" without making it the only option. Written flat
# (not as functions returning JSON via command substitution) because `exit`
# inside a `$(...)` subshell only kills the subshell, not this script — the
# cancellation short-circuits below rely on running at top level.
scope=$(gum choose --header "Pick a scope…" \
  "Today" "Overdue" "This week" "All open" "By list…") || {
  echo "aoe-pick-reminder: cancelled."
  exit 0
}

if [ -z "$scope" ]; then
  echo "aoe-pick-reminder: cancelled."
  exit 0
fi

case "$scope" in
  "Today")
    reminders_json=$(remindctl show today --json)
    ;;
  "Overdue")
    reminders_json=$(remindctl show overdue --json)
    ;;
  "This week")
    reminders_json=$(remindctl show week --json)
    ;;
  "All open")
    reminders_json=$(remindctl show open --json)
    ;;
  "By list…")
    lists_json=$(remindctl list --json)
    list_count=$(jq 'length' <<<"$lists_json")
    if [ "$list_count" -eq 0 ]; then
      echo "aoe-pick-reminder: no reminder lists found."
      exit 0
    fi

    list_lines=$(jq -r '.[] | "\(.title) (\(.reminderCount) open)"' <<<"$lists_json")

    list_selection=$(printf '%s\n' "$list_lines" | gum choose --header "Pick a list…") || {
      echo "aoe-pick-reminder: cancelled."
      exit 0
    }

    if [ -z "$list_selection" ]; then
      echo "aoe-pick-reminder: cancelled."
      exit 0
    fi

    list_title=$(sed -E 's/ \([0-9]+ open\)$//' <<<"$list_selection")

    reminders_json=$(remindctl show open --list "$list_title" --json)
    ;;
esac

count=$(jq 'length' <<<"$reminders_json")
if [ "$count" -eq 0 ]; then
  echo "aoe-pick-reminder: no reminders in that scope."
  exit 0
fi

# Each picker line embeds an 8-char id prefix in brackets so the full record
# can be recovered after gum hands back only the plain-text selection.
picker_lines=$(jq -r '
  .[] | "\(.title)  — due \(.dueDate // "no date")  [\(.id[0:8])]"
' <<<"$reminders_json")

selection=$(printf '%s\n' "$picker_lines" | gum filter --placeholder "Pick a reminder…") || {
  echo "aoe-pick-reminder: cancelled."
  exit 0
}

if [ -z "$selection" ]; then
  echo "aoe-pick-reminder: cancelled."
  exit 0
fi

prefix=$(sed -E 's/.*\[([0-9A-Fa-f]{8})\]$/\1/' <<<"$selection")

record=$(jq --arg p "$prefix" '.[] | select(.id | startswith($p))' <<<"$reminders_json")

if [ -z "$record" ]; then
  echo "aoe-pick-reminder: could not find a reminder matching selection."
  exit 0
fi

id=$(jq -r '.id' <<<"$record")
title=$(jq -r '.title' <<<"$record")
list_name=$(jq -r '.listName' <<<"$record")
due_date=$(jq -r '.dueDate // "none"' <<<"$record")
notes=$(jq -r '.notes // "" | if . == "" then "(none)" else . end' <<<"$record")

payload=$(cat <<EOF
Reminder: ${title}
List: ${list_name}
Due: ${due_date}
Notes: ${notes}
Reminder ID: ${id}

When this work is complete, mark it done by running: remindctl complete ${id}
EOF
)

printf '%s' "$payload" | pbcopy

echo "Copied reminder \"${title}\" to clipboard."
read -n 1 -s -r -p "Copied to clipboard. Press any key to close..."
echo
