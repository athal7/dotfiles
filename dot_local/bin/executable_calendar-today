#!/usr/bin/env python3
"""
Print today's calendar events, filtered to configured calendars.
Reads calendar names from chezmoi data [data.calendars].
"""

import json
import subprocess
import sys
from pathlib import Path


def get_allowed_calendars():
    result = subprocess.run(
        ["chezmoi", "data", "--format", "json"], capture_output=True, text=True
    )
    data = json.loads(result.stdout)
    return set(data.get("calendars", {}).values())


def main():
    allowed = get_allowed_calendars()
    if not allowed:
        print(
            "No calendars configured in ~/.config/chezmoi/chezmoi.toml [data.calendars]",
            file=sys.stderr,
        )
        sys.exit(1)

    ical = (
        subprocess.run(["which", "ical"], capture_output=True, text=True).stdout.strip()
        or Path.home() / ".local/bin/ical"
    )
    result = subprocess.run(
        [str(ical), "today", "-o", "json"], capture_output=True, text=True
    )
    if result.returncode != 0:
        print(result.stderr, file=sys.stderr)
        sys.exit(result.returncode)

    events = json.loads(result.stdout or "[]")
    for e in events:
        if e.get("calendar") not in allowed:
            continue
        start = e.get("start_date", "")
        time = start[11:16] if not e.get("all_day") else "all-day"
        print(f"{time} {e['title']} [{e['calendar']}]")


if __name__ == "__main__":
    main()
