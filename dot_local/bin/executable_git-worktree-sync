#!/bin/sh
# git-worktree-sync - Fast-forward default branch in repos with active worktrees
#
# Iterates over repos in ~/code/ that have git worktrees and:
# 1. Fetches the default branch from origin
# 2. Fast-forwards the local default branch via `reset --hard` so the main
#    checkout's HEAD, index, and working tree all stay in sync.
#
# Important: this assumes you do NOT do real work in the main checkout.
# If a repo has uncommitted edits in the main checkout when this runs and a
# fast-forward is possible, those edits are stashed (tagged
# "git-worktree-sync auto-stash") before the reset. Recover with `git stash list`
# / `git stash apply` if needed; prune the auto-stash entries when stale.
# A diverged main (local commits not in origin) is left alone.
#
# Designed to run on a schedule via LaunchAgent. Pairs well with
# `git maintenance` prefetch for near-instant fetches.

set -eu

CODE_DIR="${HOME}/code"
LOG_TAG="git-worktree-sync"

log() { logger -t "$LOG_TAG" "$@" 2>/dev/null; printf '%s %s\n' "$(date +%H:%M:%S)" "$*"; }

for repo in "$CODE_DIR"/*/; do
  [ -d "$repo/.git" ] || continue

  # Only process repos with active worktrees
  worktree_dir="$repo/.git/worktrees"
  [ -d "$worktree_dir" ] && [ "$(ls -A "$worktree_dir" 2>/dev/null)" ] || continue

  name=$(basename "$repo")

  # Detect default branch: worktrunk config > origin/HEAD > skip
  default_branch=$(git -C "$repo" config worktrunk.default-branch 2>/dev/null) || \
  default_branch=$(git -C "$repo" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/origin/||') || {
    log "$name: skipped (no default branch detected)"
    continue
  }

  # Fetch default branch from origin
  if ! git -C "$repo" fetch --quiet origin "$default_branch" 2>/dev/null; then
    log "$name: fetch failed"
    continue
  fi

  local_ref=$(git -C "$repo" rev-parse "refs/heads/$default_branch" 2>/dev/null) || {
    log "$name: no local $default_branch ref"
    continue
  }
  remote_ref=$(git -C "$repo" rev-parse "refs/remotes/origin/$default_branch" 2>/dev/null) || {
    log "$name: no remote $default_branch ref"
    continue
  }

  # Already up to date
  [ "$local_ref" != "$remote_ref" ] || continue

  # Only fast-forward (remote must be a descendant of local). A diverged main
  # means there are local commits not in origin -- leave it alone, that's a
  # human problem.
  if ! git -C "$repo" merge-base --is-ancestor "$local_ref" "$remote_ref" 2>/dev/null; then
    log "$name: $default_branch diverged, skipping"
    continue
  fi

  short_remote=$(echo "$remote_ref" | cut -c1-8)

  # If the main checkout is dirty, stash before the reset so nothing is lost.
  # Tag the stash message so these auto-stashes are distinguishable from
  # human-created ones and can be pruned safely.
  if [ -n "$(git -C "$repo" status --porcelain 2>/dev/null)" ]; then
    stash_msg="git-worktree-sync auto-stash $(date -u +%Y-%m-%dT%H:%M:%SZ)"
    if git -C "$repo" stash push --include-untracked --quiet --message "$stash_msg" 2>/dev/null; then
      log "$name: $default_branch had local mods, stashed and hard-reset to $short_remote"
    else
      log "$name: $default_branch had local mods, stash failed, skipping"
      continue
    fi
  else
    log "$name: $default_branch fast-forwarded to $short_remote"
  fi

  # Hard reset so HEAD, index, and working tree stay coherent. Using
  # `update-ref` here would leave the index and worktree at the old commit,
  # which is exactly the corruption mode this script used to cause.
  git -C "$repo" reset --hard --quiet "$remote_ref"
done
