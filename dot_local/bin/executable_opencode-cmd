#!/bin/sh
# opencode-cmd — CLI wrapper for the opencode HTTP API
# Uses xh + jq to manage sessions, send messages, and query state.

set -e

API="${OPENCODE_API:-http://localhost:4096}"
DIR="${OPENCODE_DIR:-$(pwd)}"
TIMEOUT=10
TIMEOUT_SET=""
AGENT=""
MODEL=""

print_usage() {
  cat >&2 <<'EOF'
Usage: opencode-cmd [OPTIONS] COMMAND [ARGS...]

Options:
  -d DIR        Working directory (default: $OPENCODE_DIR or current dir)
  -t SECS       Timeout in seconds (default: 10; no timeout for 'send' unless set)
  -a AGENT      Agent name (e.g. plan, build)
  -m PROV/MODEL Model in provider/modelID format

Commands:
  send TEXT            Create session + send message (waits for run to finish)
  create               Create session, print session ID
  list                 List sessions for directory (JSON)
  status [ID]          Session status (JSON). Without ID: all statuses.
  msg ID TEXT          Send message to existing session
  transcript ID        Get transcript (JSON)
  abort ID             Abort a running session
  delete ID            Delete session
  worktree BRANCH      Create worktree, print directory path
  questions            List pending questions (JSON)
  reply QID ANSWER     Answer a pending question
  health               Exit 0 if server reachable, 1 otherwise
  await ID             Block until session idle, print last assistant text
                       (wait timeout: 300s default, override with -t)
  ask ID TEXT          Send message to session, wait, print the reply
                       (= msg + await; honors -a AGENT and -m MODEL)
  peers                Live sessions sharing this repo/dir, with status (JSON)
  move ID DIR          Relocate a session to another directory
  wt-move ID BRANCH    Create a worktree and move session ID into it
  help                 Print this usage text (also -h, --help)
EOF
}

# Print usage and exit non-zero (unknown/empty command).
usage() {
  print_usage
  exit 1
}

die() { printf 'opencode-cmd: %s\n' "$1" >&2; exit 1; }

# ── Model parsing ────────────────────────────────────────────────────────────

# Split "provider/modelID" into PROVIDER and MODEL_ID globals.
split_model() {
  PROVIDER="${MODEL%%/*}"
  MODEL_ID="${MODEL#*/}"
  [ -n "$PROVIDER" ] && [ -n "$MODEL_ID" ] && [ "$PROVIDER" != "$MODEL" ] \
    || die "invalid model format: '$MODEL' (expected provider/modelID)"
}

# ── Body builders ────────────────────────────────────────────────────────────
# Build JSON bodies incrementally via piped jq calls. This avoids
# word-splitting issues with dynamic --arg lists in POSIX sh.

# Build JSON body for session creation.
# Session create uses model.id (not model.modelID).
build_create_body() {
  body='{}'
  if [ -n "$AGENT" ]; then
    body=$(printf '%s' "$body" | jq --arg agent "$AGENT" '. + {agent: $agent}')
  fi
  if [ -n "$MODEL" ]; then
    split_model
    body=$(printf '%s' "$body" | jq \
      --arg mid "$MODEL_ID" --arg prov "$PROVIDER" \
      '. + {model: {id: $mid, providerID: $prov}}')
  fi
  printf '%s' "$body"
}

# Build JSON body for sending a message.
# Message send uses model.modelID (API asymmetry with session create).
build_msg_body() {
  text="$1"
  body=$(jq -n --arg text "$text" '{parts: [{type: "text", text: $text}]}')
  if [ -n "$AGENT" ]; then
    body=$(printf '%s' "$body" | jq --arg agent "$AGENT" '. + {agent: $agent}')
  fi
  if [ -n "$MODEL" ]; then
    split_model
    body=$(printf '%s' "$body" | jq \
      --arg mid "$MODEL_ID" --arg prov "$PROVIDER" \
      '. + {model: {modelID: $mid, providerID: $prov}}')
  fi
  printf '%s' "$body"
}

# ── Wait / read-back helpers ───────────────────────────────────────────────────
# Used by the await/ask verbs to block on a run and read the reply.

# Fetch the full message list for a session. The v1 message endpoint returns the
# actual conversation as an array of {info:{role,...}, parts:[{type,text}]} when
# given a directory — unlike the v2 /api/.../message endpoint (used by the
# transcript verb), which only returns meta-events (model-switched, etc.) in
# this build. So await/ask read from v1 to get real assistant text.
fetch_messages() {
  xh --ignore-stdin GET "${API}/session/$1/message" "directory==${DIR}" 2>/dev/null
}

# Print the concatenated text parts of the latest assistant message.
last_assistant_text() {
  fetch_messages "$1" | jq -r '
    [.[] | select(.info.role == "assistant")] | last
    | (.parts // [] | map(select(.type == "text") | .text) | join(""))' 2>/dev/null
}

# Count COMPLETED assistant messages. The server creates an assistant record at
# run start (with time.completed == null) before any text exists, so counting all
# assistant messages would falsely signal a reply mid-run. Counting only
# completed ones gives a race-free baseline for detecting a fresh reply.
assistant_count() {
  fetch_messages "$1" | jq '
    [.[] | select(.info.role == "assistant" and .info.time.completed != null)]
    | length' 2>/dev/null
}

# Resolve the effective wait timeout: 300s default for await/ask, overridable
# with -t. (The global TIMEOUT default of 10 is for the short blocking verbs.)
wait_timeout() {
  if [ -n "$TIMEOUT_SET" ]; then printf '%s' "$TIMEOUT"; else printf '%s' 300; fi
}

# Read a session's status type, normalising the all-idle empty map (and missing
# entries) to "idle". Values seen from the server: idle, busy, retry.
status_type() {
  xh --ignore-stdin GET "${API}/session/status" 2>/dev/null \
    | jq -r --arg id "$1" '.[$id].type // "idle"' 2>/dev/null
}

# Block until the session is idle or the wait timeout elapses. Returns non-zero
# on timeout. min_replies, if >0, additionally requires the assistant-message
# count to reach that value before returning — this is how ask avoids the race
# where status is still "idle" between firing a message and the run starting.
wait_for_idle() {
  sid="$1"; min_replies="${2:-0}"
  wt=$(wait_timeout)
  deadline=$(( $(date +%s) + wt ))
  while :; do
    st=$(status_type "$sid")
    [ -n "$st" ] || st="idle"
    if [ "$st" = "idle" ]; then
      if [ "$min_replies" -le 0 ]; then
        return 0
      else
        cur=$(assistant_count "$sid"); [ -n "$cur" ] || cur=0
        [ "$cur" -ge "$min_replies" ] && return 0
      fi
    fi
    [ "$(date +%s)" -ge "$deadline" ] && return 1
    sleep 2
  done
}

# POST to the move-session control-plane endpoint. Returns the HTTP status code
# on stdout (the endpoint replies 204 No Content with an empty body).
# moveChanges is false: we never move changes (worktrees are created before any
# changes exist), and moveChanges:true would destructively clean the shared
# source working tree, clobbering sibling sessions sharing the directory.
move_session() {
  sid="$1"; dest="$2"
  body=$(jq -n --arg sid "$sid" --arg dir "$dest" \
    '{sessionID: $sid, destination: {directory: $dir}, moveChanges: false}')
  printf '%s' "$body" \
    | xh --print=hb POST "${API}/experimental/control-plane/move-session" 2>/dev/null \
    | awk 'NR==1{print $2}'
}

# ── Help (intercept before getopts, which would reject the dash forms) ─────────

case "${1:-}" in
  help|-h|--help) print_usage; exit 0 ;;
esac

# ── Option parsing ───────────────────────────────────────────────────────────

while getopts "d:t:a:m:" opt; do
  case "$opt" in
    d) DIR="$OPTARG" ;;
    t) TIMEOUT="$OPTARG"; TIMEOUT_SET=1 ;;
    a) AGENT="$OPTARG" ;;
    m) MODEL="$OPTARG" ;;
    *) usage ;;
  esac
done
shift $((OPTIND - 1))

[ $# -ge 1 ] || usage
CMD="$1"; shift

# ── Command dispatch ─────────────────────────────────────────────────────────

case "$CMD" in

  # ── send: create session + fire message ──────────────────────────────────
  send)
    [ $# -ge 1 ] || die "send requires TEXT argument"
    TEXT="$*"

    BODY=$(build_create_body)
    RESP=$(printf '%s' "$BODY" | xh POST "${API}/session" "directory==${DIR}" 2>/dev/null) \
      || die "failed to create session"
    SID=$(printf '%s' "$RESP" | jq -r '.id') || die "failed to parse session id"
    [ -n "$SID" ] && [ "$SID" != "null" ] || die "session id is empty"

    MSG_BODY=$(build_msg_body "$TEXT")
    # The message POST is synchronous: opencode holds the connection open until
    # the run finishes, which can take minutes. Applying the short default
    # timeout would disconnect mid-run and abort it server-side. Only pass
    # --timeout when the caller set one explicitly with -t; otherwise block for
    # the whole run. Discard the response body but let stderr through so
    # scheduled runs leave a trace in the log.
    if [ -n "$TIMEOUT_SET" ]; then
      printf '%s' "$MSG_BODY" \
        | xh --timeout="$TIMEOUT" POST "${API}/session/${SID}/message" "directory==${DIR}" \
          >/dev/null || true
    else
      printf '%s' "$MSG_BODY" \
        | xh POST "${API}/session/${SID}/message" "directory==${DIR}" \
          >/dev/null || true
    fi

    printf '%s\n' "$SID"
    ;;

  # ── create: new session ──────────────────────────────────────────────────
  create)
    BODY=$(build_create_body)
    printf '%s' "$BODY" \
      | xh POST "${API}/session" "directory==${DIR}" \
      | jq -r '.id'
    ;;

  # ── list: sessions for directory (v2) ────────────────────────────────────
  # v2 has no `roots` param and paginates (default 50/page), so request a high
  # limit, newest-first, then unwrap the {data, cursor} envelope and filter to
  # root sessions client-side to match the legacy roots-only output shape (a
  # bare JSON array). Legacy `roots==true` capped at 100; this returns more.
  list)
    xh --ignore-stdin GET "${API}/api/session" \
      "directory==${DIR}" "limit==1000" "order==desc" \
      | jq '[.data[] | select(.parentID == null)]'
    ;;

  # ── status: session status ───────────────────────────────────────────────
  status)
    if [ $# -ge 1 ]; then
      xh --ignore-stdin GET "${API}/session/status" \
        | jq --arg id "$1" '.[$id]'
    else
      xh --ignore-stdin GET "${API}/session/status"
    fi
    ;;

  # ── msg: send message to session ─────────────────────────────────────────
  msg)
    [ $# -ge 2 ] || die "msg requires ID and TEXT arguments"
    SID="$1"; shift
    TEXT="$*"

    BODY=$(build_msg_body "$TEXT")
    printf '%s' "$BODY" \
      | xh --timeout="$TIMEOUT" POST "${API}/session/${SID}/message" "directory==${DIR}"
    ;;

  # ── transcript: get session messages (v2) ────────────────────────────────
  # v2 reads don't need a directory and return a {data, cursor} envelope;
  # unwrap to a bare array. The message shape may differ from legacy — this is
  # an inspection dump, so that's acceptable.
  transcript)
    [ $# -ge 1 ] || die "transcript requires ID argument"
    xh --ignore-stdin GET "${API}/api/session/$1/message" \
      | jq '.data'
    ;;

  # ── abort: abort running session ─────────────────────────────────────────
  abort)
    [ $# -ge 1 ] || die "abort requires ID argument"
    xh --ignore-stdin POST "${API}/session/$1/abort" "directory==${DIR}"
    ;;

  # ── delete: remove session ───────────────────────────────────────────────
  delete)
    [ $# -ge 1 ] || die "delete requires ID argument"
    xh --ignore-stdin DELETE "${API}/session/$1" "directory==${DIR}"
    ;;

  # ── worktree: create git worktree ────────────────────────────────────────
  worktree)
    [ $# -ge 1 ] || die "worktree requires BRANCH argument"
    BODY=$(jq -n --arg name "$1" '{"name": $name}')
    printf '%s' "$BODY" \
      | xh POST "${API}/experimental/worktree" "directory==${DIR}" \
      | jq -r '.directory'
    ;;

  # ── questions: list pending questions (v2) ───────────────────────────────
  # Directory is passed as a deepObject query param (location[directory]); the
  # response is a {location, data} envelope — unwrap to a bare array matching
  # the legacy output shape [{id, sessionID, questions}].
  questions)
    xh --ignore-stdin GET "${API}/api/question/request" \
      "location[directory]==${DIR}" \
      | jq '.data'
    ;;

  # ── reply: answer a pending question (v2) ────────────────────────────────
  # The v2 reply endpoint requires the sessionID, which the legacy endpoint did
  # not. Keep the same CLI signature (reply QID ANSWER) and resolve the
  # sessionID internally: look up the pending question by QID in the directory's
  # question list, then POST to the session-scoped reply endpoint.
  reply)
    [ $# -ge 2 ] || die "reply requires QID and ANSWER arguments"
    QID="$1"; shift
    ANSWER="$*"
    SID=$(xh --ignore-stdin GET "${API}/api/question/request" \
      "location[directory]==${DIR}" \
      | jq -r --arg qid "$QID" '.data[] | select(.id == $qid) | .sessionID') \
      || die "failed to query pending questions"
    [ -n "$SID" ] && [ "$SID" != "null" ] \
      || die "no pending question '$QID' found in directory '$DIR'"
    BODY=$(jq -n --arg answer "$ANSWER" '{"answers": [[$answer]]}')
    printf '%s' "$BODY" \
      | xh POST "${API}/api/session/${SID}/question/${QID}/reply"
    ;;

  # ── health: check server reachability (v2) ───────────────────────────────
  health)
    xh --ignore-stdin GET "${API}/api/health" >/dev/null 2>&1
    ;;

  # ── await: block until session idle, print last assistant text ────────────
  # Default wait timeout is 300s, overridable with -t.
  await)
    [ $# -ge 1 ] || die "await requires ID argument"
    SID="$1"
    if wait_for_idle "$SID"; then
      last_assistant_text "$SID"
    else
      die "timed out after $(wait_timeout)s waiting for session $SID to go idle"
    fi
    ;;

  # ── ask: send a message to an existing session, wait, print the reply ──────
  # Composes msg + await: fires the message in the background (so we drive the
  # wait ourselves rather than relying on the blocking POST), then waits for the
  # run to finish and prints the new assistant turn. Honors -a AGENT and -m
  # MODEL via build_msg_body.
  ask)
    [ $# -ge 2 ] || die "ask requires ID and TEXT arguments"
    SID="$1"; shift
    TEXT="$*"

    BASE=$(assistant_count "$SID"); [ -n "$BASE" ] || BASE=0
    MSG_BODY=$(build_msg_body "$TEXT")
    # Fire and forget: the POST blocks server-side for the whole run, so run it
    # detached and let wait_for_idle observe completion independently. Requiring
    # one more assistant message than the baseline avoids returning the previous
    # turn during the brief idle window before the run spins up.
    ( printf '%s' "$MSG_BODY" \
        | xh POST "${API}/session/${SID}/message" "directory==${DIR}" \
          >/dev/null 2>&1 ) &

    if wait_for_idle "$SID" $((BASE + 1)); then
      last_assistant_text "$SID"
    else
      die "timed out after $(wait_timeout)s waiting for reply from session $SID"
    fi
    ;;

  # ── peers: live sessions that could collide in this repo ──────────────────
  # Lists root sessions whose directory resolves to the same git repository as
  # -d DIR (covers sibling worktrees of the same repo, not just the exact dir),
  # each annotated with its current status. Falls back to exact-directory match
  # when DIR is not inside a git repo. Output is a JSON array.
  peers)
    REPO_KEY=$(git -C "$DIR" rev-parse --path-format=absolute --git-common-dir 2>/dev/null) || REPO_KEY=""
    STATUSES=$(xh --ignore-stdin GET "${API}/session/status" 2>/dev/null) || STATUSES='{}'
    ALL=$(xh --ignore-stdin GET "${API}/api/session" "limit==1000" "order==desc" 2>/dev/null \
      | jq -c '[.data[] | select(.parentID == null)
               | {id, directory: .location.directory, title}]') \
      || die "failed to list sessions"

    printf '%s\n' "$ALL" | jq -c '.[]' | while IFS= read -r row; do
      sdir=$(printf '%s' "$row" | jq -r '.directory // ""')
      [ -n "$sdir" ] || continue
      if [ -n "$REPO_KEY" ]; then
        skey=$(git -C "$sdir" rev-parse --path-format=absolute --git-common-dir 2>/dev/null) || skey=""
        [ "$skey" = "$REPO_KEY" ] || continue
      else
        [ "$sdir" = "$DIR" ] || continue
      fi
      sid=$(printf '%s' "$row" | jq -r '.id')
      st=$(printf '%s' "$STATUSES" | jq -r --arg id "$sid" '.[$id].type // "idle"')
      printf '%s' "$row" | jq --arg st "$st" '{id, status: $st, directory, title}'
    done | jq -s '.'
    ;;

  # ── move: relocate a session to another directory ─────────────────────────
  move)
    [ $# -ge 2 ] || die "move requires ID and DIR arguments"
    SID="$1"; DEST="$2"
    CODE=$(move_session "$SID" "$DEST")
    case "$CODE" in
      2*) printf 'moved %s -> %s\n' "$SID" "$DEST" ;;
      *)  die "move failed (HTTP ${CODE:-?}) for session $SID" ;;
    esac
    ;;

  # ── wt-move: create a worktree and move a session into it ──────────────────
  # Convenience for the Desktop UI, which lacks first-class worktree support.
  # Composes worktree-create + move; prints the new worktree directory.
  wt-move)
    [ $# -ge 2 ] || die "wt-move requires ID and BRANCH arguments"
    SID="$1"; BRANCH="$2"
    WT_BODY=$(jq -n --arg name "$BRANCH" '{"name": $name}')
    NEWDIR=$(printf '%s' "$WT_BODY" \
      | xh POST "${API}/experimental/worktree" "directory==${DIR}" 2>/dev/null \
      | jq -r '.directory') || die "failed to create worktree '$BRANCH'"
    [ -n "$NEWDIR" ] && [ "$NEWDIR" != "null" ] || die "worktree '$BRANCH' returned no directory"
    CODE=$(move_session "$SID" "$NEWDIR")
    case "$CODE" in
      2*) printf '%s\n' "$NEWDIR" ;;
      *)  die "worktree created at $NEWDIR but move failed (HTTP ${CODE:-?}) for session $SID" ;;
    esac
    ;;

  # ── help: print usage (also handled pre-getopts for -h/--help) ────────────
  help|-h|--help)
    print_usage
    exit 0
    ;;

  *)
    die "unknown command: $CMD"
    ;;
esac
