#!/bin/sh
# check-error-logs — daily scan of LaunchAgent error logs
# When any services have new errors, dispatches an opencode session (via
# aoe-cmd, same fire-and-forget pattern as the audit/fix-prod-errors/kb-enrich/
# refactor-hotspots scheduled jobs) to triage and self-heal them — running the
# /fix-launchagent-errors command in the dotfiles repo. Dispatch-only: no
# reminder is filed.
#
# State file tracks byte offsets per log file so only new content is read.
# First run establishes a baseline and exits silently.
#
# Offset invariant: a log's byte offset is advanced only after its new errors
# have been handed off. If the dispatch does not happen (the aoe-cmd dispatch
# fails), offsets for logs that contributed errors are NOT advanced, so the
# next run retries them and no error is silently lost. Logs with no new
# errors always advance normally.

LOG_DIR="$HOME/Library/Logs"
STATE_FILE="$LOG_DIR/.check-error-logs-state"
SELF_LOG="check-error-logs.error.log"

# Per-service line exclusion patterns (grep -E extended regex).
# Lines matching the pattern are stripped before error-keyword scanning.
# Add an entry here instead of fully suppressing a noisy service.
#
# Format: one entry per line, "service_name|pattern"
# The service_name matches the basename of the .error.log file (without extension).
EXCLUDE_PATTERNS="
homebridge|Rate limited for the GetDevice API
homebridge|bonjour-hap: send EADDRNOTAVAIL
homebridge|request to https://oauth2\.googleapis\.com/token failed
"

# mlx-qwen-server: benign startup race — a previous mlx_lm.server process is
# still slowly releasing port 1234 (unloading a 30B-param model) while
# launchd's KeepAlive respawns a new instance every ~10s. The race self-heals
# within ~90s once the old process fully exits, with zero service disruption
# (RunAtLoad+KeepAlive guarantees eventual success). Confirmed no recurrence
# in 29+ hours of normal operation since the one occurrence on 2026-07-14
# (day this LaunchAgent was first deployed).
EXCLUDE_PATTERNS="$EXCLUDE_PATTERNS
mlx-qwen-server|OSError: \[Errno 48\] Address already in use
mlx-qwen-server|RuntimeError: cannot schedule new futures after interpreter shutdown
mlx-qwen-server|raise RuntimeError\('cannot schedule new futures after '
mlx-qwen-server|Exception in thread Thread-1 \(_generate\):
"

# Return the exclusion pattern for a service name, or empty string if none.
exclude_pattern_for() {
  svc="$1"
  printf '%s\n' "$EXCLUDE_PATTERNS" \
    | grep -E "^${svc}\|" \
    | cut -d'|' -f2- \
    | paste -sd'|' -
}

# Read saved byte offset for a log file (default 0)
saved_offset() {
  grep -F "$1:" "$STATE_FILE" 2>/dev/null | tail -1 | cut -d: -f2
}

# Write/update offset for a log file in state file
update_offset() {
  logfile="$1"
  offset="$2"
  tmpfile="$STATE_FILE.tmp"
  # Remove existing entry for this file, append new one
  grep -vF "$logfile:" "$STATE_FILE" 2>/dev/null > "$tmpfile" || true
  printf '%s:%s\n' "$logfile" "$offset" >> "$tmpfile"
  mv "$tmpfile" "$tmpfile.done" && mv "$tmpfile.done" "$STATE_FILE"
}

# ── First run: establish baseline ────────────────────────────────────────────
if [ ! -f "$STATE_FILE" ]; then
  echo "$(date '+%Y-%m-%d %H:%M:%S') First run — establishing baseline offsets"
  for logfile in "$LOG_DIR"/*.error.log; do
    [ -f "$logfile" ] || continue
    [ "$(basename "$logfile")" = "$SELF_LOG" ] && continue
    size=$(stat -f%z "$logfile" 2>/dev/null || echo 0)
    update_offset "$logfile" "$size"
    echo "  baseline: $(basename "$logfile") @ $size bytes"
  done
  echo "$(date '+%Y-%m-%d %H:%M:%S') Baseline complete. New errors will be reported on next run."
  exit 0
fi

# ── Daily scan ────────────────────────────────────────────────────────────────
echo "$(date '+%Y-%m-%d %H:%M:%S') Scanning error logs..."

services_with_errors=""
total_new_lines=0
error_context=""    # accumulated "[service] line" detail for the dispatch
pending_offsets=""  # deferred "size<TAB>logfile" advances (applied after dispatch)
TAB=$(printf '\t')

for logfile in "$LOG_DIR"/*.error.log; do
  [ -f "$logfile" ] || continue
  [ "$(basename "$logfile")" = "$SELF_LOG" ] && continue

  name=$(basename "$logfile" .error.log)
  current_size=$(stat -f%z "$logfile" 2>/dev/null || echo 0)
  offset=$(saved_offset "$logfile")
  offset=${offset:-0}

  # File was truncated (rotated) — reset to beginning
  if [ "$current_size" -lt "$offset" ]; then
    echo "  $name: file truncated, resetting offset"
    offset=0
  fi

  # Nothing new
  if [ "$current_size" -eq "$offset" ]; then
    update_offset "$logfile" "$current_size"
    continue
  fi

  # Read new bytes (cap at 50KB to avoid huge reads)
  new_bytes=$((current_size - offset))
  if [ "$new_bytes" -gt 51200 ]; then
    # Too much new content — read last 50KB
    read_offset=$((current_size - 51200))
  else
    read_offset=$offset
  fi

  # Get per-service exclusion pattern (may be empty)
  excl=$(exclude_pattern_for "$name")

  # Extract new content, strip known-noisy lines, then filter for error keywords
  new_raw=$(tail -c "+$((read_offset + 1))" "$logfile" 2>/dev/null)
  if [ -n "$excl" ]; then
    new_filtered=$(printf '%s\n' "$new_raw" | grep -vE "$excl")
  else
    new_filtered=$(printf '%s\n' "$new_raw")
  fi
  new_content=$(printf '%s\n' "$new_filtered" \
    | grep -iE 'error|fatal|panic|exception|failed|crash' \
    | head -20)

  new_line_count=$(printf '%s' "$new_content" | grep -c . || true)

  if [ "$new_line_count" -gt 0 ]; then
    echo "  $name: $new_line_count new error line(s)"
    printf '%s\n' "$new_content" | while IFS= read -r line; do printf '    [%s] %s\n' "$name" "$line"; done
    services_with_errors="$services_with_errors $name"
    total_new_lines=$((total_new_lines + new_line_count))

    # Retain the matched detail lines (tagged with service) as dispatch context.
    detail=$(printf '%s\n' "$new_content" | while IFS= read -r line; do printf '[%s] %s\n' "$name" "$line"; done)
    error_context="$error_context
$detail"

    # Defer this log's offset advance until the dispatch succeeds (offset
    # invariant) — record the target offset for replay after a good dispatch.
    pending_offsets="$pending_offsets$(printf '\n%s\t%s' "$current_size" "$logfile")"
  else
    echo "  $name: $new_bytes new bytes, no error-keyword lines"
    # No errors here — safe to advance the offset immediately.
    update_offset "$logfile" "$current_size"
  fi
done

# Also baseline any new log files that appeared since last run
for logfile in "$LOG_DIR"/*.error.log; do
  [ -f "$logfile" ] || continue
  [ "$(basename "$logfile")" = "$SELF_LOG" ] && continue
  # Skip logs whose offset advance is deferred pending a successful dispatch —
  # baselining them here would advance past unhandled errors (offset invariant).
  case "$pending_offsets" in
    *"$TAB$logfile") continue ;;
    *"$TAB$logfile
"*) continue ;;
  esac
  if ! grep -qF "$logfile:" "$STATE_FILE" 2>/dev/null; then
    size=$(stat -f%z "$logfile" 2>/dev/null || echo 0)
    update_offset "$logfile" "$size"
    echo "  new log detected, baselined: $(basename "$logfile") @ $size bytes"
  fi
done

echo "$(date '+%Y-%m-%d %H:%M:%S') Scan complete."

# ── Dispatch a fix session if errors found ───────────────────────────────────
if [ -n "$services_with_errors" ]; then
  service_list=$(printf '%s' "$services_with_errors" | tr ' ' ',' | sed 's/^,//')

  # Bound the context payload. The scan already caps reads at 50KB and 20
  # lines/file; keep the dispatch text similarly bounded.
  context=$(printf '%s' "$error_context" | head -c 8000)

  prompt="/fix-launchagent-errors

Services with new errors: $service_list

$context"

  # aoe-cmd is fire-and-forget: it creates the session, starts the tmux pane,
  # and sends the prompt, then exits — matching the dispatch pattern used by
  # the audit/fix-prod-errors/kb-enrich/refactor-hotspots LaunchAgent triggers.
  if aoe-cmd -d "$HOME/code/dotfiles" -n fix-launchagent-errors "$prompt" >/dev/null 2>&1; then
    echo "$(date '+%Y-%m-%d %H:%M:%S') Dispatched /fix-launchagent-errors for: $service_list"
    # Dispatch succeeded — now advance the deferred offsets for error logs.
    printf '%s\n' "$pending_offsets" | while IFS="$TAB" read -r size logfile; do
      [ -n "$logfile" ] || continue
      update_offset "$logfile" "$size"
    done
  else
    echo "$(date '+%Y-%m-%d %H:%M:%S') WARNING: dispatch failed — offsets for error logs NOT advanced; will retry next run. Services: $service_list"
    exit 0
  fi
else
  echo "$(date '+%Y-%m-%d %H:%M:%S') No new errors found."
fi
