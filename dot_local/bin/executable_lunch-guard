#!/usr/bin/env python3
"""
lunch-guard - Block lunch on calendar when it's at risk.

For each weekday in the next 2 weeks, sums busy minutes in the 11am-1pm
window. If 60+ minutes are consumed, places a 45-min Lunch block in the
first free slot in the window (or 11:00 if fully packed).

Requires: ical, chezmoi
"""

import json
import subprocess
from datetime import date, datetime, timedelta
from pathlib import Path
from zoneinfo import ZoneInfo

TAG = "Managed by lunch-guard"
WINDOW = (11 * 60, 13 * 60)  # 11:00-13:00 in minutes
RISK_THRESHOLD = 60           # busy minutes that trigger a block
DURATION = 45                 # lunch block length


def ical(*args):
    ical_bin = subprocess.run(["which", "ical"], capture_output=True, text=True).stdout.strip() \
               or str(Path.home() / ".local/bin/ical")
    result = subprocess.run([ical_bin, *args], capture_output=True, text=True)
    return json.loads(result.stdout or "[]")


def chezmoi_data():
    result = subprocess.run(
        ["chezmoi", "data", "--format", "json"],
        capture_output=True, text=True
    )
    return json.loads(result.stdout)


def local_tz():
    import os
    return ZoneInfo(os.readlink("/etc/localtime").split("zoneinfo/")[-1])


def to_min(dt_str, tz):
    """Convert ISO datetime string to minutes since midnight in local tz."""
    dt = datetime.fromisoformat(dt_str.replace("Z", "+00:00")).astimezone(tz)
    return dt.hour * 60 + dt.minute


def from_min(m):
    return f"{m // 60:02d}:{m % 60:02d}"


def busy_intervals(events, tz):
    """Return sorted list of (start_min, end_min) for blocking events."""
    intervals = []
    for e in events:
        if e.get("all_day"):
            continue
        if e.get("title") == "Lunch":
            continue
        if e.get("availability") == "free":
            continue
        intervals.append((to_min(e["start_date"], tz), to_min(e["end_date"], tz)))
    return sorted(intervals)


def busy_in_window(intervals, ws, we):
    total = 0
    for s, e in intervals:
        cs, ce = max(s, ws), min(e, we)
        if ce > cs:
            total += ce - cs
    return total


def first_free_slot(intervals, ws, we, duration):
    """Return start of first free slot of `duration` mins in [ws, we], or ws if none."""
    cursor = ws
    for s, e in intervals:
        s, e = max(s, ws), min(e, we)
        if s > cursor and s - cursor >= duration:
            return cursor
        if e > cursor:
            cursor = e
    return cursor if we - cursor >= duration else ws


def process_day(day, cal, tz):
    if day.weekday() >= 5:
        return

    events = ical("list", "-c", cal, "--from", str(day), "--to", str(day), "-o", "json")

    guard = next((e for e in events if e.get("notes", "").strip() == TAG), None)

    intervals = busy_intervals(events, tz)
    busy_mins = busy_in_window(intervals, *WINDOW)

    if busy_mins < RISK_THRESHOLD:
        if guard:
            log(f"{day}: OK ({busy_mins}min busy), removing guard event")
            ical("delete", guard["id"], "--force")
        else:
            log(f"{day}: OK ({busy_mins}min busy)")
        return

    if guard:
        log(f"{day}: AT RISK ({busy_mins}min busy), guard exists")
        return

    slot = first_free_slot(intervals, *WINDOW, DURATION)
    st, et = from_min(slot), from_min(slot + DURATION)
    log(f"{day}: AT RISK ({busy_mins}min busy), creating Lunch {st}-{et}")
    ical("add", "Lunch",
         "-c", cal,
         "-s", f"{day} {st}",
         "-e", f"{day} {et}",
         "--notes", TAG)


def log(msg):
    print(f"{datetime.now().strftime('%H:%M:%S')} {msg}", flush=True)
    subprocess.run(["logger", "-t", "lunch-guard", msg], capture_output=True)


if __name__ == "__main__":
    tz = local_tz()
    data = chezmoi_data()
    cal = data.get("calendars", {}).get("work", "Work")
    today = date.today()
    for i in range(14):
        day = today + timedelta(days=i)
        try:
            process_day(day, cal, tz)
        except Exception as e:
            log(f"ERROR {day}: {e}")
    log("done")
