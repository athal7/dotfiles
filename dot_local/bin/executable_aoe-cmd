#!/bin/sh
# aoe-cmd — dispatch a scheduled opencode session through aoe (Agent of
# Empires) instead of hitting the opencode HTTP API directly, so the session
# shows up in aoe's session list/TUI/`aoe serve` dashboard like an
# interactively-created one.
#
# Fire-and-forget by design: creates a terminal-view session (opencode
# running inside a tmux pane, same mode a plain `aoe add` produces) and types
# a message into it, then exits. There is no blocking "wait for the agent's
# reply" verb for these sessions — the point of moving to aoe is that the
# session persists and is reviewable later via `aoe`/`aoe serve`, unlike
# blocking on an HTTP call ever did.
#
# Launching is two calls, not one: `aoe add DIR --tool opencode --title
# TITLE` to create the session record, then `aoe session start ID` to
# actually start the tmux pane running opencode. This is deliberately NOT
# `aoe add ... -l/--launch`, which tries to interactively attach to the new
# tmux session right after creating it — in the non-TTY context this script
# always runs in (a LaunchAgent has no controlling terminal), that attach
# attempt fails and `aoe add` exits 1 even though the session, tmux pane, and
# opencode process were all created successfully. Live-tested: `aoe add ...
# -l` reliably returns exit 1 in this environment despite fully succeeding,
# which would make every scheduled run look like a failure and abort before
# ever sending a message. Splitting into `aoe add` (no -l, just creates the
# record, exits 0) + `aoe session start` (starts the tmux process without
# attaching, exits 0) avoids the spurious failure and gives a reliable exit
# code at each step.
#
# `aoe add` does not error or dedupe on a repeated --title — repeated runs
# with the same NAME would produce multiple sessions sharing a title. So the
# title always gets a timestamp suffix, and the numeric session ID (parsed
# from `aoe add`'s output) is what's used for the follow-up `session start`
# and `send` calls — never the title.
#
# opencode's TUI takes a few seconds to boot inside the fresh tmux pane.
# `aoe send` types straight into the pane with no readiness check and no ACK:
# a message sent before opencode is ready is silently dropped — `aoe send`
# still prints its "Sent message" confirmation and exits 0, so there's no
# error signal to retry on. This used to be handled with a fixed sleep after
# `aoe session start` returns, before calling `aoe send` once — that design
# was falsified by real evidence: under unattended 20:00 weekday LaunchAgent
# runs (kb-enrich, fix-prod-errors), the fixed 5s sleep silently dropped the
# send in 4/4 recent runs (tmux panes still showed opencode's pristine
# welcome screen; zero opencode sessions were created in
# ~/.local/share/opencode/opencode.db for those runs), because boot time
# under real unattended conditions isn't reliably bounded by a guessed
# constant. The fix is a bounded poll: after `aoe session start` returns,
# repeatedly capture the pane (`aoe session capture`) and check for
# opencode's input placeholder text, sending only once that marker appears
# (or failing loudly if it never does within a timeout). Retrying the send
# itself would overcomplicate a fire-and-forget tool, so there's still just
# one `aoe send` call — only the wait before it is adaptive now.
#
# `aoe send` gets the message with a trailing space appended. All 4 real
# scheduled jobs send a slash command (e.g. `/audit`); opencode's TUI treats
# a leading `/` as the start of its slash-command autocomplete dropdown, and
# `aoe send`'s trailing Enter keystroke gets consumed by that dropdown
# (dismissing/accepting it) instead of submitting the message — so the
# command sits typed-but-unsubmitted forever while `aoe send` still reports
# success. A trailing space closes the dropdown as it's typed, so the Enter
# that follows submits normally. Live-tested against the real `audit`
# LaunchAgent: without the trailing space `/audit` was typed but stuck in
# the dropdown indefinitely; with it, `/audit` submitted immediately and the
# workflow ran. Harmless for plain-text messages too.
#
# Usage:
#   aoe-cmd -d DIR -n NAME MESSAGE...
#
# Env:
#   AOE_CMD_READY_TIMEOUT   Max seconds to poll the pane for the ready marker
#                           after `aoe session start` before giving up
#                           (default 30).
#   AOE_CMD_POLL_INTERVAL   Seconds to sleep between poll attempts (default
#                           1). Override to 0 in tests.
#   AOE_CMD_READY_MARKER    Text to look for in the captured pane that
#                           indicates opencode's TUI is ready for input
#                           (default "Ask anything...").

set -eu

usage() {
  echo "Usage: aoe-cmd -d DIR -n NAME MESSAGE..." >&2
}

dir=""
name=""

while getopts "d:n:" opt; do
  case "$opt" in
    d) dir="$OPTARG" ;;
    n) name="$OPTARG" ;;
    *) usage; exit 1 ;;
  esac
done
shift $((OPTIND - 1))

message="$*"

if [ -z "$dir" ] || [ -z "$name" ] || [ -z "$message" ]; then
  usage
  exit 1
fi

title="${name}-$(date +%Y%m%d-%H%M%S)"

if ! add_output=$(aoe add "$dir" --tool opencode --title "$title"); then
  echo "aoe-cmd: 'aoe add' failed for session '$title'" >&2
  exit 1
fi

id=$(printf '%s\n' "$add_output" | awk '/^  ID:/ {print $2}')

if [ -z "$id" ]; then
  echo "aoe-cmd: could not parse session ID from 'aoe add' output for '$title':" >&2
  printf '%s\n' "$add_output" >&2
  exit 1
fi

if ! start_output=$(aoe session start "$id" 2>&1); then
  echo "aoe-cmd: 'aoe session start' failed for session '$title' (id $id)" >&2
  printf '%s\n' "$start_output" >&2
  exit 1
fi

# Wait for opencode's TUI to be ready for input before sending. `aoe send`
# has no delivery ACK — a send into a still-booting pane is silently dropped
# (proven under unattended 20:00 LaunchAgent runs: 4/4 recent dispatches left
# the pane on opencode's untouched welcome screen and never created an
# opencode session, despite `aoe send` reporting success every time). Poll
# the pane for opencode's input placeholder instead of guessing a fixed sleep.
ready_timeout="${AOE_CMD_READY_TIMEOUT:-30}"
poll_interval="${AOE_CMD_POLL_INTERVAL:-1}"
ready_marker="${AOE_CMD_READY_MARKER:-Ask anything...}"

waited=0
ready=0
pane=""
while [ "$waited" -lt "$ready_timeout" ]; do
  sleep "$poll_interval"
  # `+ (poll_interval == 0)` guards against an infinite loop when
  # AOE_CMD_POLL_INTERVAL=0 (used in tests to keep the suite fast): without
  # it, a zero interval would never advance `waited` and this loop would
  # never hit the timeout bound. No-op for the real default of 1.
  waited=$((waited + poll_interval + (poll_interval == 0)))
  pane=$(aoe session capture "$id" --lines 50 --strip-ansi 2>/dev/null) || pane=""
  case "$pane" in
    *"$ready_marker"*) ready=1; break ;;
  esac
done

if [ "$ready" -ne 1 ]; then
  echo "aoe-cmd: opencode TUI never became ready (no '$ready_marker' after ${ready_timeout}s) for session '$title' (id $id); not sending" >&2
  printf '%s\n' "$pane" >&2
  exit 1
fi

if ! send_output=$(aoe send "$id" "$message " 2>&1); then
  echo "aoe-cmd: 'aoe send' failed for session '$title' (id $id)" >&2
  printf '%s\n' "$send_output" >&2
  exit 1
fi

echo "aoe-cmd: dispatched '$title' (id $id)"
