#!/usr/bin/env python3
"""
sync-calendars - Mirror busy blocks between configured calendars.

For each calendar with sync_to set, finds real events and ensures matching
"Busy" blocks exist on destination calendars. Cleans up stale mirrors when
the source event is gone. Calendars with readonly=true are never written to.

Requires: ical, chezmoi
"""

import json
import os
import re
import subprocess
from datetime import date, datetime, timedelta
from pathlib import Path
from zoneinfo import ZoneInfo

MARKER = "Managed by sync-calendars"
OLD_MARKER = "Automatically generated by Shortcuts"
WEEKS = 4
WORK_START = 9   # 9am
WORK_END = 17    # 5pm

# Exact-match titles to mirror as-is; everything else becomes "Busy"
DISPLAY_NAMES = {
    "lunch", "dr", "standup", "retrospective",
    "cycle planning", "planning", "1-1", "demo",
}

_ICAL_BIN = None


def ical_bin():
    global _ICAL_BIN
    if not _ICAL_BIN:
        _ICAL_BIN = subprocess.run(
            ["which", "ical"], capture_output=True, text=True
        ).stdout.strip() or str(Path.home() / ".local/bin/ical")
    return _ICAL_BIN


def ical(*args):
    result = subprocess.run([ical_bin(), *args], capture_output=True, text=True)
    return json.loads(result.stdout or "[]")


def ical_write(*args):
    subprocess.run([ical_bin(), *args], capture_output=True, text=True)


def chezmoi_data():
    result = subprocess.run(
        ["chezmoi", "data", "--format", "json"],
        capture_output=True, text=True
    )
    return json.loads(result.stdout)


def local_tz():
    return ZoneInfo(os.readlink("/etc/localtime").split("zoneinfo/")[-1])


def to_local(dt_str, tz):
    return datetime.fromisoformat(dt_str.replace("Z", "+00:00")).astimezone(tz)


def is_one_on_one(title, first_name):
    """Return True if title looks like 'Name / Name' with my first name."""
    return bool(re.search(r'\b' + re.escape(first_name) + r'\b', title, re.IGNORECASE)) \
        and '/' in title


def mirror_title(event, first_name):
    """Return the title to use for the mirror event."""
    title = event.get("title", "").strip()
    lower = title.lower()
    if is_one_on_one(title, first_name):
        return "1-1"
    for name in DISPLAY_NAMES:
        if name in lower:
            return name.capitalize()
    return "Busy"


def in_working_hours(event, tz):
    """Return True if event starts during working hours (Mon-Fri, 9am-5pm local time)."""
    start = to_local(event["start_date"], tz)
    return start.weekday() < 5 and WORK_START <= start.hour < WORK_END


def is_excluded(event, src_label, sync_exclude):
    """Return True if this event should be skipped based on syncExclude config."""
    title = event.get("title", "").strip().lower()
    for pattern, cal_label in sync_exclude.items():
        if pattern.lower() == title:
            if cal_label == "*" or cal_label == src_label:
                return True
    return False


def events_for(calendar, src_label, from_date, to_date, tz, sync_exclude):
    """Fetch real (non-mirror) events for a calendar."""
    events = ical("list", "-c", calendar, "--from", from_date, "--to", to_date, "-o", "json")
    return [
        e for e in events
        if not e.get("all_day")
        and e.get("notes", "").strip() not in (MARKER, OLD_MARKER)
        and e.get("title", "").lower() != "out of office"
        and e.get("availability") != "free"
        and e.get("status") != "cancelled"
        and in_working_hours(e, tz)
        and not is_excluded(e, src_label, sync_exclude)
    ]


def mirrors_for(calendar, from_date, to_date, markers=(MARKER,)):
    """Fetch mirror events managed by this script."""
    events = ical("list", "-c", calendar, "--from", from_date, "--to", to_date, "-o", "json")
    return [e for e in events if e.get("notes", "").strip() in markers]


def find_mirror(mirrors, start, end):
    return next(
        (m for m in mirrors if m["start_date"] == start and m["end_date"] == end),
        None
    )


def delete_all_markers(calendars, from_date, to_date, markers):
    """Remove all events with given marker notes across all calendars."""
    for label, cal in calendars.items():
        name = cal["name"]
        events = mirrors_for(name, from_date, to_date, markers=markers)
        for e in events:
            log(f"Removing old marker event from {name} ({e['start_date'][:16]}): {e['title']}")
            ical_write("delete", e["id"], "--force")


def log(msg):
    print(f"{datetime.now().strftime('%H:%M:%S')} {msg}", flush=True)
    subprocess.run(["logger", "-t", "sync-calendars", msg], capture_output=True)


def main():
    data = chezmoi_data()
    calendars = data.get("calendars", {})  # {label: {name, readonly, sync_to, ...}}
    first_name = data.get("fullName", "").split()[0]
    sync_exclude = calendars.get("syncExclude", {})
    from_date = str(date.today())
    to_date = str(date.today() + timedelta(weeks=WEEKS))
    tz = local_tz()

    # Filter to real calendar entries (exclude syncExclude sub-key)
    cal_entries = {k: v for k, v in calendars.items() if isinstance(v, dict)}

    if len(cal_entries) < 2:
        log("Need at least 2 calendars configured, skipping")
        return

    # Derive sync rules and writable calendars from attributes
    sync_rules = {
        label: cal.get("sync_to", [])
        for label, cal in cal_entries.items()
        if cal.get("sync_to")
    }
    write_labels = {k: v["name"] for k, v in cal_entries.items() if not v.get("readonly", False)}

    # Fetch real events from all source calendars
    all_events = {
        label: events_for(cal["name"], label, from_date, to_date, tz, sync_exclude)
        for label, cal in cal_entries.items()
        if label in sync_rules
    }

    # Fetch existing mirrors from writable calendars
    all_mirrors = {
        label: mirrors_for(name, from_date, to_date, markers={MARKER, OLD_MARKER})
        for label, name in write_labels.items()
    }

    # Phase 1: remove stale mirrors (no matching source event)
    # Build set of expected (dst_label, start, end) from current source events
    expected = set()
    for src_label, dst_labels in sync_rules.items():
        if src_label not in cal_entries:
            continue
        for event in all_events.get(src_label, []):
            for dst_label in dst_labels:
                if dst_label in write_labels:
                    expected.add((dst_label, event["start_date"], event["end_date"]))

    for dst_label, mirrors in all_mirrors.items():
        for mirror in mirrors:
            key = (dst_label, mirror["start_date"], mirror["end_date"])
            if key not in expected:
                log(f"Removing stale mirror from {write_labels[dst_label]} ({mirror['start_date'][:16]}): {mirror['title']}")
                ical_write("delete", mirror["id"], "--force")

    # Phase 2: create missing mirrors
    # Build set of already-mirrored (dst_label, start, end)
    mirrored = {
        (dst_label, m["start_date"], m["end_date"])
        for dst_label, mirrors in all_mirrors.items()
        for m in mirrors
    }
    # Also track what we create this run to avoid duplicates
    created = set()

    for src_label, dst_labels in sync_rules.items():
        if src_label not in cal_entries:
            continue
        for event in all_events.get(src_label, []):
            start, end = event["start_date"], event["end_date"]
            title = mirror_title(event, first_name)

            for dst_label in dst_labels:
                if dst_label not in write_labels:
                    continue
                key = (dst_label, start, end)
                if key in mirrored or key in created:
                    continue
                # Skip if a real event already covers this slot on dst
                if any(e["start_date"] == start and e["end_date"] == end
                       for e in all_events.get(dst_label, [])):
                    continue

                log(f"Adding '{title}' to {write_labels[dst_label]} ({start[:16]})")
                ical_write("add", title,
                           "-c", write_labels[dst_label],
                           "-s", start,
                           "-e", end,
                           "--notes", MARKER,
                           "--no-alert")
                created.add(key)

    log("done")


if __name__ == "__main__":
    main()
