#!/usr/bin/env bash
# lumen-diff — pick the right lumen invocation for the current branch
#
# lumen's --detect-pr mode gives real viewed-state persistence tied to the
# PR (survives across machines/sessions), but it hard-exits if the current
# branch has no open PR. This repo has no PR workflow — changes land via
# chezmoi-deploy — so most branches never have one. Fall back to a local
# --watch diff against main in that case, which still gets per-file
# viewed-state tracking, just scoped to this checkout.
#
# Use `main..-` (lumen's range+working-tree union syntax), not the more
# obvious `main...HEAD`. `main..-` deliberately includes uncommitted
# working-tree changes, which is the whole point of this wrapper during an
# in-progress agent session that hasn't committed yet. `main...HEAD` alone
# is a committed-only range — it would silently show nothing until a
# commit is made.
set -u

if gh pr view >/dev/null 2>&1; then
  exec lumen diff --detect-pr
else
  exec lumen diff --watch main..-
fi
