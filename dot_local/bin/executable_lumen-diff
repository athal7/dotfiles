#!/usr/bin/env bash
# lumen-diff — review the current branch's diff with persistent, local
# viewed-state tracking.
#
# lumen's --watch mode has no built-in persistence — quit the TUI and the
# viewed-file marks are gone. We roll our own: a per-repo, per-branch JSON
# file at $XDG_STATE_HOME/lumen-diff/<repo-slug>/<branch>.json (XDG Base
# Directory convention) mapping each changed file's path to the
# `git hash-object` of its working-tree content at last review.
# Content-hash-keyed (not diff-hash-keyed) means it's rebase-stable: if
# main advances but a file's bytes haven't changed, it stays
# marked-reviewed. Only files whose current
# hash differs from the stored one get passed to lumen; if nothing
# qualifies, we skip launching lumen entirely. This tracking is intentionally
# local-only and does not sync to GitHub's PR-viewed-state — deliberately
# simpler than reconciling local edits against a pushed PR's head, which
# lumen's own --detect-pr mode cannot do (it force-disables --watch and only
# ever diffs against the PR's last-pushed head, so local edits made after a
# push become invisible until the next push).
#
# Use `main..-` (lumen's range+working-tree union syntax), not the more
# obvious `main...HEAD`. `main..-` deliberately includes uncommitted
# working-tree changes, which is the whole point of this wrapper during an
# in-progress agent session that hasn't committed yet. `main...HEAD` alone
# is a committed-only range — it would silently show nothing until a
# commit is made.
#
# This script is typically launched as the command inside a tmux tool pane
# with `remain-on-exit on` (aoe's pattern). The moment the foreground process
# actually exits, that pane goes dead/tombstoned. `lumen` treats Ctrl+C the
# same as a clean quit (rc=0), so a Ctrl+C bail-out marks everything reviewed
# and the very next launch finds nothing unreviewed — if either exit point
# below used bare `exit`, the pane would die immediately, every retry, with
# no way back in. Both exit `exec "${SHELL:-bash}"` instead, landing at a
# live shell prompt in the repo so the pane stays usable.
set -u

full=0
reset=0
extra_args=()
for arg in "$@"; do
  case "$arg" in
    --full) full=1 ;;
    --reset) reset=1 ;;
    *) extra_args+=("$arg") ;;
  esac
done
if [[ "${LUMEN_DIFF_FULL:-}" == "1" ]]; then
  full=1
fi

state_root="${XDG_STATE_HOME:-$HOME/.local/state}/lumen-diff"

# host/owner/repo, normalized so every worktree of the same remote
# shares one state directory regardless of clone URL scheme.
repo_slug() {
  local url
  url="$(git remote get-url origin 2>/dev/null)" || return 1
  url="${url%.git}"
  case "$url" in
    git@*:*)
      url="${url#git@}"
      url="${url/:/\/}"
      ;;
    ssh://git@*)
      url="${url#ssh://git@}"
      ;;
    https://*)
      url="${url#https://}"
      ;;
    http://*)
      url="${url#http://}"
      ;;
  esac
  printf '%s' "$url"
}

# branch names can contain `/`; sanitize for use as a single filename.
sanitize_branch() { printf '%s' "${1//\//__}"; }

# branch names can contain `/`; desanitize for comparison against refs.
desanitize_branch() { printf '%s' "${1//__/\/}"; }

fallback_watch() {
  echo "lumen-diff: $1" >&2
  exec lumen diff --watch main..- "${extra_args[@]}"
}

root="$(git rev-parse --show-toplevel 2>/dev/null)" || fallback_watch "not in a git repo, no persistent state"
slug="$(repo_slug)" || fallback_watch "no 'origin' remote, no persistent state"
repo_dir="$state_root/$slug"

# Prune state files for branches that no longer exist, best-effort.
if [[ -d "$repo_dir" ]]; then
  shopt -s nullglob
  stale_candidates=("$repo_dir"/*.json)
  shopt -u nullglob
  for f in "${stale_candidates[@]}"; do
    b="$(desanitize_branch "$(basename "$f" .json)")"
    if ! git -C "$root" show-ref --verify --quiet "refs/heads/$b" 2>/dev/null; then
      rm -f "$f" 2>/dev/null || true
    fi
  done
fi

branch="$(git branch --show-current)"
[[ -n "$branch" ]] || fallback_watch "detached HEAD, no persistent state"

state_file="$repo_dir/$(sanitize_branch "$branch").json"

if (( reset )); then
  rm -f "$state_file" 2>/dev/null || true
fi

state_json='{"schema":1,"files":{}}'
if [[ -f "$state_file" ]]; then
  if parsed="$(jq -c '.' "$state_file" 2>/dev/null)" && \
     [[ "$(jq -r '.schema // empty' <<<"$parsed" 2>/dev/null)" == "1" ]]; then
    state_json="$parsed"
  else
    echo "lumen-diff: ignoring unreadable or incompatible state file: $state_file" >&2
  fi
fi

base="$(git -C "$root" merge-base main HEAD 2>/dev/null)" || fallback_watch "can't find merge-base with main, no persistent state"

# Walk the NUL-delimited name-status stream; rename/copy entries carry an
# extra old-path field before the path we actually care about (the new one).
changed_paths=()
declare -A cur_hash=()
while IFS= read -r -d '' status && IFS= read -r -d '' path; do
  case "$status" in
    R*|C*) IFS= read -r -d '' path || break ;;
  esac
  changed_paths+=("$path")
  cur_hash["$path"]="$(git -C "$root" hash-object -- "$path" 2>/dev/null)" || cur_hash["$path"]="__deleted__"
done < <(git -C "$root" diff --name-status -z "$base")

show_set=()
for path in "${changed_paths[@]}"; do
  if (( full )); then
    show_set+=("$path")
    continue
  fi
  stored="$(jq -r --arg p "$path" '.files[$p] // ""' <<<"$state_json")"
  if [[ "${cur_hash[$path]}" != "$stored" ]]; then
    show_set+=("$path")
  fi
done

if [[ ${#show_set[@]} -eq 0 ]]; then
  echo "lumen-diff: no unreviewed changes on '$branch' (all reviewed). Use --full to re-review."
  exec "${SHELL:-bash}"
fi

file_args=()
for path in "${show_set[@]}"; do
  file_args+=(--file "$path")
done

lumen diff --watch main..- "${extra_args[@]}" "${file_args[@]}"
rc=$?

if [[ $rc -eq 0 ]]; then
  mkdir -p "$repo_dir"
  files_json='{}'
  for path in "${changed_paths[@]}"; do
    files_json="$(jq -c --arg p "$path" --arg h "${cur_hash[$path]}" '. + {($p): $h}' <<<"$files_json")"
  done
  tmp="$state_file.tmp.$$"
  if jq -n --argjson files "$files_json" '{schema: 1, files: $files}' > "$tmp"; then
    mv "$tmp" "$state_file"
  else
    rm -f "$tmp" 2>/dev/null || true
  fi
fi

exec "${SHELL:-bash}"
